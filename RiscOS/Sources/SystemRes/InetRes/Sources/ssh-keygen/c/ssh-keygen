/*
 * Command line interface
 */
static const char *allowed_ktypes(void)
{
  static char list[100];
  size_t i;
  bool any = false;

  for (i = 0; i < KTYPE_MAX; i++)
  {
    if (ktypes[i].defbits > 0)
    {
      if (any) strcat(list, ",");
      strcat(list, ktypes[i].name);
      any = true;
    }
  }
  return list;
}

static const char *allowed_kformats(void)
{
  static char list[100];
  size_t i;
  bool any = false;

  for (i = 0; i < KFORMAT_MAX; i++)
  {
    if (kformats[i].implemented)
    {
      if (any) strcat(list, ",");
      strcat(list, kformats[i].name);
      any = true;
    }
  }
  return list;
}

static noreturn void usage(void)
{
  fprintf(stderr,
"Usage:   ssh-keygen [-qv] [-b bits] [-C comment] [-t type] [-m format] [-f keyfile]\n"
"Options: -t  set the key type to be one of [%s]\n"
"         -m  set the %s key output format to be one of [%s]\n"
"         -b  number of bits in the key\n"
"         -C  provide a comment\n"
"         -f  names the output key file\n"
"         -q  be somewhat quiet\n"
"         -v  be verbose\n", allowed_ktypes(),
                       M_PRIVATE_FORMAT_ONLY ? "private" : "",
                       allowed_kformats());
  exit(EX_USAGE);
}

int main(int argc, char **argv)
{
  mbedtls_entropy_context entropy;
  mbedtls_ctr_drbg_context ctr_drbg;
  mbedtls_pk_context key;
  char leaf[256], custom[64];
  const char *errmsg = NULL;
  char *comment = NULL;
  time_t now;
  size_t i;
  int ch, mbederr = EX_OK;
  static_assert(EX_OK == MBEDTLS_EXIT_SUCCESS, "Clash between sysexits.h and mbedtls/platform.h");

  while ((ch = getopt(argc, argv, "Aa:Bb:C:cD:E:eF:f:gHhI:iKkLlM:m:N:n:O:P:pQqR:r:s:t:UuV:vw:Y:yZ:z:")) != -1)
  {
    switch (ch)
    {
      case 't':
        for (i = 0; i < KTYPE_MAX; i++)
        {
          if (strcasecmp(ktypes[i].name, optarg) == 0) break;
        }
        if ((i == KTYPE_MAX) || (ktypes[i].defbits <= 0))
        {
          errx(EX_USAGE, "Keys of type '%s' may not be generated with this tool", optarg);
        }
        type = (ktype_t)i;
        break;
      case 'm':
        for (i = 0; i < KFORMAT_MAX; i++)
        {
          if (strcasecmp(kformats[i].name, optarg) == 0) break;
        }
        if ((i == KFORMAT_MAX) || !kformats[i].implemented)
        {
          errx(EX_USAGE, "Keys of format '%s' may not be generated with this tool", optarg);
        }
        format = (kformat_t)i;
        break;
      case 'b':
        bits = atoi(optarg);
        break;
      case 'C':
        comment = optarg;
        break;
      case 'f':
        outfile = optarg;
        break;
      case 'q':
        quiet = true;
        verbose = 0;
        break;
      case 'v':
        if (verbose < 3) verbose++; /* Saturate at 3 */
        quiet = false;
        break;
      case 'h':
        if (strcmp(argv[optind], "-help") == 0) usage();
        /* Fall through */
      case 'A': case 'a':
      case 'B':
      case 'c':
      case 'D':
      case 'E': case 'e':
      case 'F':
      case 'g':
      case 'H':
      case 'I': case 'i':
      case 'K': case 'k':
      case 'L': case 'l':
      case 'M':
      case 'N': case 'n':
      case 'O':
      case 'P': case 'p':
      case 'Q':
      case 'R': case 'r':
      case 's':
      case 'T':
      case 'U': case 'u':
      case 'V':
      case 'w':
      case 'Y': case 'y':
      case 'Z': case 'z':
        errx(EX_USAGE, "Option -%c is not currently implemented", ch);
    }
  }
  if (argc - optind != 0) usage();

  /* Set the default bits if unset at the command line */
  if (bits == -1)
  {
    bits = ktypes[type].defbits;
    if (verbose > 2) fprintf(stderr, "Bits was unset, defaulting to %u\n", bits);
  }
  if (bits < ktypes[type].minbits)
  {
    errx(EX_USAGE, "Too few bits for key, minimum is %u", ktypes[type].minbits);
  }
  if (bits > ktypes[type].maxbits)
  {
    errx(EX_USAGE, "Too many bits for key, maximum is %u", ktypes[type].maxbits);
  }

  /* Set the default comment if unset at the command line */
  if (comment == NULL)
  {
    int len = osvarlen("Inet$HostName", VarType_Expanded);

    comment = "RISC OS";
    if (len > 0)
    {
      comment = malloc(len + 1);
      if (comment)
      {
        _swix(OS_ReadVarVal, _INR(0,4), "Inet$HostName", comment, len + 1, 0, VarType_Expanded);
        comment[len] = '\0';
      }
    }
    if (verbose > 2) fprintf(stderr, "Comment was unset, defaulting to '%s'\n", comment);
  }

  /* Set the output filename if unset at the command line */
  if (outfile == NULL)
  {
    static char temp[2 + L_tmpnam] = "@.";
    char *name, *leaf;

    name = tmpnam(&temp[2]);
    leaf = strrchr(name, '.');
    if (leaf == NULL) leaf = ".key";
    leaf++; /* Advance past the dot */
    i = strlen(leaf);
    memmove(&temp[2], leaf, i); temp[2 + i] = '\0';
    outfile = temp;
    if (verbose > 2) fprintf(stderr, "Output file was unset, defaulting to '%s'\n", outfile);
  }

  /* Initialise components */
  if (verbose > 2) fprintf(stderr, "Initialising MPI maths and entropy\n");
  mbedtls_entropy_init(&entropy);
  mbedtls_pk_init(&key);
  mbedtls_ctr_drbg_init(&ctr_drbg);

#if defined(MBEDTLS_USE_PSA_CRYPTO)
  if (verbose > 2) fprintf(stderr, "Initialising PSA Crypto\n");
  psa_status_t status = psa_crypto_init();
  if (status != PSA_SUCCESS)
  {
    errx(EX_SOFTWARE, "Failed to initialise PSA Crypto: %d", (int)status);
  }
#endif /* MBEDTLS_USE_PSA_CRYPTO */

  if (verbose > 2) fprintf(stderr, "Gathering entropy\n");
  i = (_swi(OS_ReadMonotonicTime, _RETURN(0)) & 0xFF) + 1 /* Minimum 1 stir */;
  while (i)
  {
    mbedtls_entropy_gather(&entropy);
    i--;
  }

  if (verbose > 2) fprintf(stderr, "Initialising mbedtls_ctr_drbg_seed\n");
  now = time(NULL); /* Append a tiny bit more entropy */
  snprintf(custom, sizeof(custom), "%s.%s", __progname, asctime(gmtime(&now)));
  mbederr = mbedtls_ctr_drbg_seed(&ctr_drbg, mbedtls_entropy_func, &entropy,
                                  (const unsigned char *)custom, strlen(custom));
  if (mbederr != 0)
  {
    errmsg = "Failed mbedtls_ctr_drbg_seed returned -0x%04x";
    goto tidyup;
  }

  /* Generate the key */
  if (!quiet) fprintf(stderr, "Generating public/private %s key of %u bits\n", ktypes[type].name, bits);
  mbederr = mbedtls_pk_setup(&key, mbedtls_pk_info_from_type((mbedtls_pk_type_t)MBEDTLS_PK_RSA));
  if (mbederr != 0)
  {
    errmsg = "Failed mbedtls_pk_setup returned -0x%04x";
    goto tidyup;
  }
#if defined(MBEDTLS_RSA_C) && defined(MBEDTLS_GENPRIME)
  mbederr = mbedtls_rsa_gen_key(mbedtls_pk_rsa(key), mbedtls_ctr_drbg_random, &ctr_drbg,
                                bits, 65537);
  if (mbederr != 0)
  {
    errmsg = "Failed mbedtls_rsa_gen_key returned -0x%04x";
    goto tidyup;
  }
#else
#error "Need RSA functions to generate RSA keys"
#endif /* MBEDTLS_RSA_C */

  /* Export the key */
  if (!quiet) fprintf(stderr, "Writing private key to %s\n", outfile);
  strcpy(leaf, outfile);
  mbederr = (format == KFORMAT_PEM) ? write_private_key(&key, leaf)
                                    : write_openssh_private_key(&key, leaf, comment);
  if (mbederr != 0)
  {
    errmsg = "Failed writing private key with -0x%04x";
    goto tidyup;
  }

  if (!quiet) fprintf(stderr, "Writing public key to %s/pub\n", outfile);
  strcpy(leaf, outfile);
  strcat(leaf, "/pub");
#if M_PRIVATE_FORMAT_ONLY
  mbederr = write_openssh_public_key(&key, leaf, comment);
#else
  mbederr = (format == KFORMAT_PEM) ? write_public_key(&key, leaf)
                                    : write_openssh_public_key(&key, leaf, comment);
#endif
  if (mbederr != 0)
  {
    errmsg = "Failed writing public key with -0x%04x";
    goto tidyup;
  }

  /* Success */
  mbederr = EX_OK;
tidyup:
  mbedtls_pk_free(&key);
  mbedtls_ctr_drbg_free(&ctr_drbg);
  mbedtls_entropy_free(&entropy);
#if defined(MBEDTLS_USE_PSA_CRYPTO)
  mbedtls_psa_crypto_free();
#endif /* MBEDTLS_USE_PSA_CRYPTO */
  if (mbederr != 0) errx(EX_SOFTWARE, errmsg, -mbederr);

  return mbederr;
}
