typedef enum
{
  KTYPE_DSA,
  KTYPE_ECDSA,
  KTYPE_ECDSA_SK,
  KTYPE_ED25519,
  KTYPE_ED25519_SK,
  KTYPE_RSA,
#define RSA_MIN_BITS    0x400
#define RSA_DEF_BITS    0xC00
#define RSA_MAX_BITS    0x4000
  /* Number of key types */
  KTYPE_MAX
} ktype_t;
typedef struct
{
  const char *name;
  int   minbits, maxbits, defbits;
} ktypeinfo_t;
static const ktypeinfo_t ktypes[KTYPE_MAX] =
{
  { "dsa",        0, 0, -1 },
  { "ecdsa",      0, 0, -1 },
  { "ecdsa-sk",   0, 0, -1 },
  { "ed25519",    0, 0, -1 },
  { "ed25519-sk", 0, 0, -1 },
  { "rsa",        1024, MBEDTLS_MPI_MAX_BITS, 2048 }
};

typedef enum
{
  KFORMAT_OPENSSH,
  KFORMAT_PKCS8,
  KFORMAT_PEM,
  /* Number of private key formats */
  KFORMAT_MAX
} kformat_t;
typedef struct
{
  const char *name;
  bool  implemented;
} kformatinfo_t;
static const kformatinfo_t kformats[KFORMAT_MAX] =
{
  { "openssh", true },
  { "pkcs8",   false },
  { "pem",     true }
};

static bool quiet = false;
static int verbose;
static int bits = -1;
static ktype_t type = KTYPE_RSA;
static kformat_t format = KFORMAT_OPENSSH;
static char *outfile;

/*
 * OpenSSH supporting functions
 */
static size_t openssh_be_value(char *buf, size_t val)
{
  /* Write an unaligned length word out big endian */
  buf[0] = val >> 24;
  buf[1] = val >> 16;
  buf[2] = val >> 8;
  buf[3] = val >> 0;

  return 4;
}

static size_t openssh_encode(char *buf, size_t len, const char *raw)
{
  size_t signedlen = len, skip = 4;

  /* Write a polynomial out with a length descriptor */
  if (*raw & 0x80)
  {
    /* Encode negative */
    signedlen++;
    buf[skip] = 0;
    skip++;
  }
  openssh_be_value(buf, signedlen);
  memcpy(&buf[skip], raw, len);
  return 4 + signedlen;
}

static int write_openssh_public_key(mbedtls_pk_context *key, const char *output_file, const char *comment)
{
  static const unsigned char prefix[] = { 0x00, 0x00, 0x00, 0x07, 's', 's', 'h', '-', 'r', 's', 'a' };
  int mbederr;
  FILE *f;
  char output_buf[8000];
  char *raw, *encoded, *c = output_buf;
  size_t total, offset, len;
  mbedtls_rsa_context *rsa = mbedtls_pk_rsa(*key);
  char *nraw, *eraw;
  size_t nlen, elen;
  mbedtls_mpi N, E;

  raw = encoded = NULL;
  mbedtls_mpi_init(&N); mbedtls_mpi_init(&E);
  mbederr = mbedtls_rsa_export(rsa, &N, NULL, NULL, NULL, &E);
  if (mbederr != 0) goto exporterr;

  /* Grab some space for the raw keys */
  elen = mbedtls_mpi_size(&E);
  nlen = mbedtls_mpi_size(&N);
  raw = malloc(elen + nlen);
  if (raw == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  offset = 0;
  eraw = &raw[offset]; offset += elen;
  nraw = &raw[offset]; offset += nlen;

  /* Export the public exponent */
  mbederr = mbedtls_mpi_write_binary(&E, (unsigned char *)eraw, elen);
  if (mbederr != 0) goto exporterr;
  offset += elen;

  /* Export the modulus */
  mbederr = mbedtls_mpi_write_binary(&N, (unsigned char *)nraw, nlen);
  if (mbederr != 0) goto exporterr;
  offset += nlen;

  /* Work out encoded length including header prefix, allowing for all negative polynomials */
  total = sizeof(prefix) + elen + nlen + (2 * 5);
  encoded = malloc(total);
  if (encoded == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;

  /* Build the encoded binary representation */
  memcpy(encoded, prefix, sizeof(prefix));
  len = sizeof(prefix);
  len += openssh_encode(&encoded[len], elen, eraw);
  len += openssh_encode(&encoded[len], nlen, nraw);

  /* Convert the encoded binary to base64 printable */
  total = len;
  strcpy(c, "ssh-rsa ");
  c += strlen("ssh-rsa ");
  mbederr = mbedtls_base64_encode((unsigned char *)c, sizeof(output_buf) - strlen("ssh-rsa ") - 1 /* Terminator */,
                                  &offset, (unsigned char *)encoded, total);
  if (mbederr != 0) goto exporterr;

  c[offset] = '\0';
  c = output_buf;

  /* Write it */
  f = fopen(output_file, "wb");
  if (f == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  len = strlen((const char *)c);
  if (fwrite(c, 1, len, f) != len)
  {
    fclose(f);
    return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  }

  /* Append any comment */
  len = comment ? strlen(comment) : 0;
  if (len)
  {
    fputc(' ', f);
    if (fwrite(comment, 1, len, f) != len)
    {
      fclose(f);
      return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
    }
  }
  fputc('\n', f);
  fclose(f);
  _swix(OS_File, _INR(0,2), OSFile_SetType, output_file, FileType_Text);
exporterr:
  free(raw);
  free(encoded);
  mbedtls_mpi_free(&N); mbedtls_mpi_free(&E);
  return mbederr;
}

static int write_openssh_private_key(mbedtls_pk_context *key, const char *output_file, const char *comment)
{
  static const unsigned char prefix[] = { 0x00, 0x00, 0x00, 0x07, 's', 's', 'h', '-', 'r', 's', 'a' };
  int mbederr;
  FILE *f;
  char output_buf[8000];
  char *raw, *encoded, *hdr, *subhdr, *c = output_buf;
  size_t total, offset, len;
  mbedtls_rsa_context *rsa = mbedtls_pk_rsa(*key);
  char *nraw, *praw, *qraw, *draw, *eraw, *qpraw;
  size_t nlen, plen, qlen, dlen, elen, qplen;
  mbedtls_mpi N, P, Q, D, E, QP;

#define OPENSSH_BEGIN_PRIVATE_KEY "-----BEGIN OPENSSH PRIVATE KEY-----"
#define OPENSSH_END_PRIVATE_KEY   "-----END OPENSSH PRIVATE KEY-----"
#define OPENSSH_BEGIN_END_LEN     strlen(OPENSSH_BEGIN_PRIVATE_KEY /* + */ OPENSSH_END_PRIVATE_KEY)
#define OPENSSH_PADDING           "\x01\x02\x03\x04\x05\x06\x07\x08"
#define OPENSSH_BLOCK_SIZE        8
#define OPENSSH_PRETTY_WRAP       70

  raw = encoded = NULL;
  mbedtls_mpi_init(&N); mbedtls_mpi_init(&P); mbedtls_mpi_init(&Q);
  mbedtls_mpi_init(&D); mbedtls_mpi_init(&E); mbedtls_mpi_init(&QP);
  mbederr = mbedtls_rsa_export(rsa, &N, &P, &Q, &D, &E);
  if (mbederr != 0) goto exporterr;
  mbederr = mbedtls_rsa_export_crt(rsa, NULL, NULL, &QP);
  if (mbederr != 0) goto exporterr;

  /* Grab some space for the raw keys */
  nlen = mbedtls_mpi_size(&N);
  plen = mbedtls_mpi_size(&P);
  qlen = mbedtls_mpi_size(&Q);
  dlen = mbedtls_mpi_size(&D);
  elen = mbedtls_mpi_size(&E);
  qplen = mbedtls_mpi_size(&QP);
  raw = malloc(nlen + plen + qlen + dlen + elen + qplen);
  if (raw == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  offset = 0;
  nraw =  &raw[offset]; offset += nlen;
  praw =  &raw[offset]; offset += plen;
  qraw =  &raw[offset]; offset += qlen;
  draw =  &raw[offset]; offset += dlen;
  eraw =  &raw[offset]; offset += elen;
  qpraw = &raw[offset]; offset += qplen;

  /* Export the modulus */
  mbederr = mbedtls_mpi_write_binary(&N, (unsigned char *)nraw, nlen);
  if (mbederr != 0) goto exporterr;

  /* Export the prime p */
  mbederr = mbedtls_mpi_write_binary(&P, (unsigned char *)praw, plen);
  if (mbederr != 0) goto exporterr;

  /* Export the prime q */
  mbederr = mbedtls_mpi_write_binary(&Q, (unsigned char *)qraw, qlen);
  if (mbederr != 0) goto exporterr;

  /* Export the private exponent */
  mbederr = mbedtls_mpi_write_binary(&D, (unsigned char *)draw, dlen);
  if (mbederr != 0) goto exporterr;

  /* Export the public exponent */
  mbederr = mbedtls_mpi_write_binary(&E, (unsigned char *)eraw, elen);
  if (mbederr != 0) goto exporterr;

  /* Export the inverse Q mod P */
  mbederr = mbedtls_mpi_write_binary(&QP, (unsigned char *)qpraw, qplen);
  if (mbederr != 0) goto exporterr;

  /* Work out encoded length including header prefix, allowing for all negative polynomials */
  total = strlen("openssh-key-v1") + 1 + 8 + 8 + 4 + 4 +
          4 + sizeof(prefix) + elen + nlen + (2 * 5) +
          4 + sizeof(prefix) + nlen + elen + dlen + qplen + plen + qlen + (6 * 5) +
          4 + strlen(comment) +
          OPENSSH_BLOCK_SIZE;
  encoded = malloc(total);
  if (encoded == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;

  /* Outermost header structure */
  hdr = encoded;
  strcpy(hdr,   "openssh-key-v1");
  hdr += strlen("openssh-key-v1") + 1; /* Include the terminator */
  memcpy(hdr, "\x00\x00\x00\x04none\x00\x00\x00\x04none", 8 + 8);
  hdr += 8 + 8; /* Cipher and KDF name */
  hdr += openssh_be_value(hdr, 0); /* No options */
  hdr += openssh_be_value(hdr, 1); /* Number of keys */

  /* Remember where the public key starts for later length fixup */
  subhdr = hdr;
  hdr += 4;
  memcpy(hdr, prefix, sizeof(prefix));
  len = sizeof(prefix);
  len += openssh_encode(&hdr[len], elen, eraw);
  len += openssh_encode(&hdr[len], nlen, nraw);
  hdr += len;
  openssh_be_value(subhdr, hdr - subhdr - 4); /* Fixup length */

  /* Remember where the private key starts for later length fixup */
  subhdr = hdr;
  hdr += 4;
  memcpy(hdr, "RISCRISC", 4 + 4); /* Arbitrary check value since no password */
  hdr += 4 + 4;
  memcpy(hdr, prefix, sizeof(prefix));
  len = sizeof(prefix);
  len += openssh_encode(&hdr[len], nlen, nraw);
  len += openssh_encode(&hdr[len], elen, eraw);
  len += openssh_encode(&hdr[len], dlen, draw);
  len += openssh_encode(&hdr[len], qplen, qpraw);
  len += openssh_encode(&hdr[len], plen, praw);
  len += openssh_encode(&hdr[len], qlen, qraw);
  hdr += len;

  /* Append any comment */
  len = comment ? strlen(comment) : 0;
  hdr += openssh_be_value(hdr, len); /* Comment length */
  if (len)
  {
    strcpy(hdr, comment);
    hdr += len;
  }

  /* Pad to block size */
  len = (hdr - subhdr - 4) % OPENSSH_BLOCK_SIZE;
  if (len)
  {
    len = OPENSSH_BLOCK_SIZE - len;
    memcpy(hdr, OPENSSH_PADDING, len);
    hdr += len;
  }
  openssh_be_value(subhdr, hdr - subhdr - 4); /* Fixup length */

  /* Convert the raw binary to base64 printable */
  total = hdr - encoded;
  mbederr = mbedtls_base64_encode((unsigned char *)c, sizeof(output_buf) - OPENSSH_BEGIN_END_LEN - 1 /* Terminator */,
                                  &offset, (unsigned char *)encoded, total);
  if (mbederr != 0) return mbederr;

  c[offset] = '\0';
  c = output_buf;

  /* Write it */
  f = fopen(output_file, "wb");
  if (f == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  len = strlen((const char *)c);
  fprintf(f, "%s", OPENSSH_BEGIN_PRIVATE_KEY); /* Top */

  /* Wrap the base64 part so it looks OK in an editor */
  while (len)
  {
    size_t wrap;

    fputc('\n', f);
    wrap = MIN(len, OPENSSH_PRETTY_WRAP);
    if (fwrite(c, 1, wrap, f) != wrap)
    {
      fclose(f);
      return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
    }
    c   += wrap;
    len -= wrap;
  }

  fprintf(f, "\n%s\n", OPENSSH_END_PRIVATE_KEY); /* Tail */
  fclose(f);
  _swix(OS_File, _INR(0,2), OSFile_SetType, output_file, FileType_Text);
exporterr:
  free(raw);
  free(encoded);
  mbedtls_mpi_free(&N); mbedtls_mpi_free(&P); mbedtls_mpi_free(&Q);
  mbedtls_mpi_free(&D); mbedtls_mpi_free(&E); mbedtls_mpi_free(&QP);
  return mbederr;
}

/*
 * PEM supporting functions
 */
#if !M_PRIVATE_FORMAT_ONLY
static int write_public_key(mbedtls_pk_context *key, const char *output_file)
{
  int mbederr;
  FILE *f;
  char output_buf[8000];
  char *c = output_buf;
  size_t len = 0;

  memset(output_buf, 0, sizeof(output_buf));
  mbederr = mbedtls_pk_write_pubkey_pem(key, (unsigned char *)output_buf, sizeof(output_buf));
  if (mbederr != 0) return mbederr;
  len = strlen(output_buf);

  f = fopen(output_file, "wb");
  if (f == NULL) return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  if (fwrite(c, 1, len, f) != len)
  {
    fclose(f);
    return MBEDTLS_ERR_ERROR_GENERIC_ERROR;
  }
  fclose(f);
  _swix(OS_File, _INR(0,2), OSFile_SetType, output_file, FileType_Text);
  return 0;
}
#endif

