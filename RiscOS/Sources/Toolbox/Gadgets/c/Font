/* Modernised 2026 (rewritten from s.Font; behaviour unchanged). */
/* Title:   Font.c
 * Purpose: Font SWI veneers for the TextGadgets module.
 *          Previously hand-written assembler (s.Font); reimplemented in C
 *          using _swix / _kernel_swi with the identical register contract.
 */

#include <stddef.h>          /* NULL */

#include "kernel.h"
#include "swis.h"

#include "tboxlibint/twimp.h"
#include "Font.h"

/* Finds a font.  On success the handle is written through font_handle (if a
 * non-NULL pointer is supplied), matching the original veneer. */
_kernel_oserror *font_find_font(const char *font,
        unsigned int width, unsigned int height,
        int x_res, int y_res,
        unsigned int *font_handle)
{
  _kernel_oserror *e;
  int handle;

  e = _swix(Font_FindFont, _INR(1,5) | _OUT(0),
            font, width, height, x_res, y_res,
            &handle);
  if (e)
    return e;

  if (font_handle)
    *font_handle = (unsigned int)handle;

  return NULL;
}

/* Loses a font. */
_kernel_oserror *font_lose_font(unsigned int font_handle)
{
  return _swix(Font_LoseFont, _IN(0), font_handle);
}

/* Paints some text in the current font. */
_kernel_oserror *font_paint(unsigned int font_handle,
        const char *text, unsigned int plot_type,
        int x, int y, FontCoord *coord,
        FontTransform *transform, unsigned int length)
{
  return _swix(Font_Paint, _INR(0,7),
               font_handle, text, plot_type, x, y,
               coord, transform, length);
}

/* Converts OS-unit coordinates to points. */
_kernel_oserror *font_convert_to_points(int x, int y,
        int *new_x, int *new_y)
{
  _kernel_oserror *e;
  int px, py;

  e = _swix(Font_Converttopoints, _INR(1,2) | _OUTR(1,2),
            x, y, &px, &py);
  if (e)
    return e;

  if (new_x)
    *new_x = px;
  if (new_y)
    *new_y = py;

  return NULL;
}

/* Scans a string.  This faithfully reproduces the register dataflow of the
 * original s.Font veneer (pos <- R1, new_x <- R3, new_y <- R4, count <- the
 * passed-in length); _kernel_swi is used so the exact registers are carried
 * across unchanged. */
_kernel_oserror *font_scan_string(unsigned int font_handle,
        const char *text, unsigned int plot_type,
        int x, int y, FontScanStringCoordsBlock *coords,
        FontTransform *transform,
        unsigned int length, char **pos,
        int *new_x, int *new_y, unsigned int *count)
{
  _kernel_swi_regs r;
  _kernel_oserror *e;

  r.r[0] = (int)font_handle;
  r.r[1] = (int)text;
  r.r[2] = (int)plot_type;
  r.r[3] = x;
  r.r[4] = y;
  r.r[5] = (int)coords;
  r.r[6] = (int)transform;
  r.r[7] = (int)length;

  e = _kernel_swi(Font_ScanString, &r, &r);
  if (e)
    return e;

  if (pos)
    *pos = (char *)r.r[1];
  if (new_x)
    *new_x = r.r[3];
  if (new_y)
    *new_y = r.r[4];
  if (count)
    *count = length;

  return NULL;
}
