/*
 * Name        : snprivate.c
 * Purpose     : Veneer for method TreeView_SetNodePrivateWord
 * Description : Sets the private word of the current node
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_set_node_private_word
 * Description : Sets the private word of the current node
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 *               void *private_word
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_set_node_private_word ( unsigned int flags,
                                                         ObjectId window,
                                                         ComponentId gadget,
                                                         void *private_word
                                                       )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_SetNodePrivateWord;
  r.r[3] = (int) gadget;
  r.r[4] = (int) private_word;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

