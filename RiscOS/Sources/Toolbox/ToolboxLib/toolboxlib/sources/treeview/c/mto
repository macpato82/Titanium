/*
 * Name        : mto.c
 * Purpose     : Veneer for method TreeView_MoveTo
 * Description : Sets the current node to the one specified
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_move_to
 * Description : Sets the current node to the one specified
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 *               int id
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_move_to ( unsigned int flags,
                                           ObjectId window,
                                           ComponentId gadget,
                                           int id
                                         )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_MoveTo;
  r.r[3] = (int) gadget;
  r.r[4] = (int) id;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

