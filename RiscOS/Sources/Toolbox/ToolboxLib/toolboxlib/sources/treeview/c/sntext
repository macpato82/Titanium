/*
 * Name        : sntext.c
 * Purpose     : Veneer for method TreeView_SetNodeText
 * Description : Sets the text for the current node
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_set_node_text
 * Description : Sets the text for the current node
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 *               const char *text
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_set_node_text ( unsigned int flags,
                                                 ObjectId window,
                                                 ComponentId gadget,
                                                 const char *text
                                               )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_SetNodeText;
  r.r[3] = (int) gadget;
  r.r[4] = (int) text;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

