/*
 * Name        : makevis.c
 * Purpose     : Veneer for method TreeView_MakeVisible
 * Description : Scrolls the tree so that the current node is in the visiable area
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_make_visible
 * Description : Scrolls the tree so that the current node is in the visiable area
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_make_visible ( unsigned int flags,
                                                ObjectId window,
                                                ComponentId gadget
                                              )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_MakeVisible;
  r.r[3] = (int) gadget;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

