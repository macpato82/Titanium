/*
 * Name        : mchild.c
 * Purpose     : Veneer for method TreeView_MoveChild
 * Description : Sets the current node to its parent
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_move_child
 * Description : Sets the current node to its parent
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : int *id
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_move_child ( unsigned int flags,
                                              ObjectId window,
                                              ComponentId gadget,
                                              int *id
                                            )
{
  _kernel_swi_regs r;
  _kernel_oserror *e;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_MoveChild;
  r.r[3] = (int) gadget;
  if ((e = _kernel_swi(Toolbox_ObjectMiscOp,&r,&r)) == NULL)
  {
    if (id != NULL) *id = (int) r.r[0];
  }

  return (e);
}

