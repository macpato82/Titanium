/*
 * Name        : selnode.c
 * Purpose     : Veneer for method TreeView_SelectNode
 * Description : Selects or deselects the current node
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_select_node
 * Description : Selects or deselects the current node
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_select_node ( unsigned int flags,
                                               ObjectId window,
                                               ComponentId gadget
                                             )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_SelectNode;
  r.r[3] = (int) gadget;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

