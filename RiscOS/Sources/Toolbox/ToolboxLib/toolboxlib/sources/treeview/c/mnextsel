/*
 * Name        : mnextsel.c
 * Purpose     : Veneer for method TreeView_MoveNextSelected
 * Description : Moves the current node to be the next selected node
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_move_next_selected
 * Description : Moves the current node to be the next selected node
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : int *new_id
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_move_next_selected ( unsigned int flags,
                                                      ObjectId window,
                                                      ComponentId gadget,
                                                      int *new_id
                                                    )
{
  _kernel_swi_regs r;
  _kernel_oserror *e;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_MoveNextSelected;
  r.r[3] = (int) gadget;
  if ((e = _kernel_swi(Toolbox_ObjectMiscOp,&r,&r)) == NULL)
  {
    if (new_id != NULL) *new_id = (int) r.r[0];
  }

  return (e);
}

