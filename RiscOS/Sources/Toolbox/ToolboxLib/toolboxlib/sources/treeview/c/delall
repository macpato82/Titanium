/*
 * Name        : delall.c
 * Purpose     : Veneer for method TreeView_DeleteAll
 * Description : Deletes the entire tree
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_delete_all
 * Description : Deletes the entire tree
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_delete_all ( unsigned int flags,
                                              ObjectId window,
                                              ComponentId gadget
                                            )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_DeleteAll;
  r.r[3] = (int) gadget;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

