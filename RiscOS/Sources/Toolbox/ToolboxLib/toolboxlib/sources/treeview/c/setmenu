/*
 * Name        : setmenu.c
 * Purpose     : Veneer for method TreeView_SetMenu
 * Description : Sets the menu to be displayed when the user clicks Menu over the gadget
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_set_menu
 * Description : Sets the menu to be displayed when the user clicks Menu over the gadget
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 *               ObjectId menu
 * Out         : None
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_set_menu ( unsigned int flags,
                                            ObjectId window,
                                            ComponentId gadget,
                                            ObjectId menu
                                          )
{
  _kernel_swi_regs r;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_SetMenu;
  r.r[3] = (int) gadget;
  r.r[4] = (int) menu;
  return (_kernel_swi(Toolbox_ObjectMiscOp,&r,&r));
}

