/*
 * Name        : getmenu.c
 * Purpose     : Veneer for method TreeView_GetMenu
 * Description : Gets the menu that would be displayed when the user clicks Menu over the gadget
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "treeview.h"




/*
 * Name        : treeview_get_menu
 * Description : Gets the menu that would be displayed when the user clicks Menu over the gadget
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : ObjectId *menu
 * Returns     : pointer to error block
 */

extern _kernel_oserror *treeview_get_menu ( unsigned int flags,
                                            ObjectId window,
                                            ComponentId gadget,
                                            ObjectId *menu
                                          )
{
  _kernel_swi_regs r;
  _kernel_oserror *e;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = TreeView_GetMenu;
  r.r[3] = (int) gadget;
  if ((e = _kernel_swi(Toolbox_ObjectMiscOp,&r,&r)) == NULL)
  {
    if (menu != NULL) *menu = (ObjectId) r.r[0];
  }

  return (e);
}

