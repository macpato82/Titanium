/* Modernised 2026 (formatting/structure only; behaviour unchanged). */


/*
 * Name        : getlabel.c
 * Purpose     : Veneer for method Tabs_GetLabel
 * Description : Gets the tab name of the given tab
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "tabs.h"




/*
 * Name        : tabs_get_label
 * Description : Gets the tab name of the given tab
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 *               int tab_index
 *               char *buffer
 *               int buffsize
 * Out         : int *nbytes
 * Returns     : pointer to error block
 */

extern _kernel_oserror *tabs_get_label ( unsigned int flags,
                                         ObjectId window,
                                         ComponentId gadget,
                                         int tab_index,
                                         char *buffer,
                                         int buffsize,
                                         int *nbytes
                                       )
{
  _kernel_swi_regs r;
  _kernel_oserror *e;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = Tabs_GetLabel;
  r.r[3] = (int) gadget;
  r.r[4] = (int) tab_index;
  r.r[5] = (int) buffer;
  r.r[6] = (int) buffsize;
  if ((e = _kernel_swi(Toolbox_ObjectMiscOp,&r,&r)) == NULL)
  {
    if (nbytes != NULL) *nbytes = (int) r.r[0];
  }

  return(e);
}

