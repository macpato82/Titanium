/*
 * Name        : getstate.c
 * Purpose     : Veneer for method Tabs_GetState
 * Description : Gets the gadget flags for the given tab
 */


#include "kernel.h"
#include "toolbox.h"
#include "gadgets.h"
#include "tabs.h"




/*
 * Name        : tabs_get_state
 * Description : Gets the gadget flags for the given tab
 * In          : unsigned int flags
 *               ObjectId window
 *               ComponentId gadget
 * Out         : unsigned int *state
 * Returns     : pointer to error block
 */

extern _kernel_oserror *tabs_get_state ( unsigned int flags,
                                         ObjectId window,
                                         ComponentId gadget,
                                         unsigned int *state
                                       )
{
  _kernel_swi_regs r;
  _kernel_oserror *e;

  r.r[0] = flags;
  r.r[1] = (int) window;
  r.r[2] = Tabs_GetState;
  r.r[3] = (int) gadget;
  if ((e = _kernel_swi(Toolbox_ObjectMiscOp,&r,&r)) == NULL)
  {
    if (state != NULL) *state = (unsigned int) r.r[0];
  }

  return(e);
}

