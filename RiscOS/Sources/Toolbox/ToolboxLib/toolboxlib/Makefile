COMPONENT = toolboxlib
LIBRARIES = ${LIBRARY}
EXPDIR   ?= ${LIBDIR}${SEP}tboxlibs
HDRS      =  \
  colourdbox \
  colourmenu \
  dcs        \
  fileinfo   \
  fontdbox   \
  fontmenu   \
  gadgets    \
  iconbar    \
  menu       \
  printdbox  \
  proginfo   \
  quit       \
  saveas     \
  scale      \
  Scrollbar  \
  ScrollList \
  tabs       \
  TextArea   \
  toolbox    \
  treeview   \
  wimp       \
  window
CINCLUDES = -I.
CAPPFLAGS = ${C_NO_STKCHK}
CUSTOMLIB = custom
SOURCES_TO_SYMLINK = $(wildcard sources/*/c/*)

include CLibrary

ifeq (,${MAKE_VERSION})

# RISC OS / amu case

