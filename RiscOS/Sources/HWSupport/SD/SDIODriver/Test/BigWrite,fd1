ON ERROR ON ERROR OFF:REPORT:PRINT;" at line ";ERL:END
PRINT "Large write test"
PRINT "BE SURE YOU DON'T CARE ABOUT THE CONTENTS OF THE DEVICE!"
INPUT "Drive? "dr%
INPUT "Number of sectors to store: "sectors%

DIM out% 512*sectors%, back% 512*sectors%
PROCfill_random(out%)
SYS"SDFS_DiscOp",,2,dr%<<29,out%,512*sectors%
SYS"SDFS_DiscOp",,1,dr%<<290,back%,512*sectors%
PROCcompare(out%,back%)
END

DEF PROCfill_random(a%)
IF RND(-TIME)
LOCAL i%
FOR i%=0 TO 512*sectors%-4 STEP 4
  a%!i%=RND(65536)+(RND(65536)<<16)
NEXT
ENDPROC

DEF PROCcompare(a%,b%)
LOCAL i%
FOR i%=0 TO 512*sectors%-4 STEP 4
  IF a%!i%<>b%!i% THEN ERROR 1,"Difference between &"+STR$~a%+" and &"+STR$~b%+" at offset &"+STR$~i%
NEXT
ENDPROC
