ON ERROR ON ERROR OFF:REPORT:PRINT;" at line ";ERL:END
PRINT "Multi-block op test"
INPUT "Bus? "bus%
INPUT "Slot? "slot%
SYS"SDIO_Enumerate",1,,(bus%<<8)+slot% TO ,,r2%
rca%=r2%>>>16
PRINT '"RCA is &";RIGHT$("000"+STR$~rca%,4)

DIM buf% 512*65536
DIM blk1% 12, blk2% 12
blk1%!0=23
blk2%!0=(9<<12)+18
blk2%!4=0

PROCselect
ON ERROR ON ERROR OFF:PROCdeselect:REPORT:PRINT;" at line ";ERL:END

REPEAT

INPUT "Number of sectors to read? "count%
blk1%!4=count%
SYS"SDIO_Op",&E0000+(bus%<<8)+slot%,12,blk1%,,,100
SYS"SDIO_Op",&10E0000+(bus%<<8)+slot%,12,blk2%,buf%,512*count%,100

UNTIL FALSE
END

DEF PROCselect
LOCAL blk%
DIM blk% LOCAL 12
blk%!0=7
blk%!4=rca%<<16
SYS"SDIO_Op",&E0000+(bus%<<8)+slot%,12,blk%,,,100
ENDPROC

DEF PROCdeselect
LOCAL blk%
DIM blk% LOCAL 8
blk%!0=7
blk%!4=0
SYS"SDIO_Op",(bus%<<8)+slot%,8,blk%,,,100
ENDPROC
