#include <stdio.h>
#include <stdint.h>
#include "swis.h"

static void callback(void)
{
  __asm {
        STR     r0, [r12]
  }
}

int main(int argc, char *argv)
{
  (void) argc;
  (void) argv;

  int bus, slot;

  printf("Background vs foreground SD operation speed comparison\n");
  printf("Bus? ");
  scanf(" %i", &bus);
  printf("Slot? ");
  scanf(" %i", &slot);

  uint32_t countFG = 0, countBG = 0;
  int32_t t, end; // signed so difference is automatically signed without cast
  uint32_t command[] = { 0, 0 };

  /* Repeatedly do foreground CMD0 ops for a second */
  _swi(OS_ReadMonotonicTime, _OUT(0), &t);
  do _swi(OS_ReadMonotonicTime, _OUT(0), &end); while (end == t);
  end += 100;
  do {
    _swi(SDIO_Op, _INR(0,2)|_INR(4,5),
        (slot << 0) | (bus << 8),
        8,
        command,
        0,
        10);
    _swi(OS_ReadMonotonicTime, _OUT(0), &t);
    ++countFG;
  } while (t - end < 0);

  /* Repeatedly do background CMD0 ops for another second */
  static _kernel_oserror *volatile bg_status;
  uint32_t bg_handle;
  _swi(OS_ReadMonotonicTime, _OUT(0), &t);
  do _swi(OS_ReadMonotonicTime, _OUT(0), &end); while (end == t);
  end += 100;
  do {
    bg_status = (void *) -1;
    _swi(SDIO_Op, _INR(0,2)|_INR(4,7)|_OUT(1),
        (slot << 0) | (bus << 8) | (1u << 29),
        8,
        command,
        0,
        0,
        callback,
        &bg_status,
        &bg_handle);
    do  {
      _swi(OS_ReadMonotonicTime, _OUT(0), &t);
    } while (t - end < 0 && bg_status == (void *) -1);
    if (t - end < 0)
      ++countBG;
  } while (t - end < 0);
  _swi(SDIO_Control, _INR(0,2), 5, (slot << 0) | (bus << 8), bg_handle);

  printf("Foreground ops per second: %u\n", countFG);
  printf("Background ops per second: %u\n", countBG);
}
