#ifndef OS_ConvertVariform
#define OS_ConvertVariform (0xED)
#endif
#ifndef ConvertToFixedFileSize
#define ConvertToFixedFileSize (8)
#endif

/** The size threshold between SDHC and SDXC cards. In general we can treat SDHC
 * and SDXC identically - the exception is in the *SDIODevices command! */
#define SDXC_THRESHOLD (32ull << 30)

_kernel_oserror *command_sdiodevices(void)
{
  printf(message_lookup_direct("SDIODevHdr"));
  printf("\n");

  for (ctrlnode_t *ctrl = g_ctrl; ctrl != NULL; ctrl = ctrl->next)
  {
    for (uint32_t sloti = 0; sloti < ctrl->dev->slots; sloti++)
    {
      sdmmcslot_t *slot = ctrl->slot + sloti;
      if (swi_Control_lock(ctrl->bus, sloti) == NULL)
      {
        if (slot->card_detect_state == CD_ANNOUNCED)
        {
          if (slot->memory_type != MEMORY_NONE)
          {
            for (uint32_t cardi = 0; cardi < MAX_CARDS_PER_SLOT; cardi++)
            {
              sdmmccard_t *card = slot->card + cardi;
              if (card->in_use)
              {
                const char *desc, *name, *vendor;
                char cap_buf[12] = "", vendor_buf[4], name_buf[8];
                uint32_t version, date, year, month;

                switch (slot->memory_type)
                {
                  case MEMORY_MMC:       desc = "MMC card"; break;
                  case MEMORY_SD:        desc = "SD card"; break;
                  case MEMORY_SDHC_SDXC: desc = card->capacity < SDXC_THRESHOLD ? "SDHC card" : "SDXC card"; break;
                  default: desc = "Error";
                }

                _swix(OS_ConvertVariform, _INR(0,4), &card->capacity, cap_buf, sizeof cap_buf, 8, ConvertToFixedFileSize);

                if (slot->memory_type == MEMORY_MMC)
                {
                  vendor = message_lookup_direct("BadString");
                  name = cardreg_read_string(card->cid, CID_PNM_MMC, name_buf);
                  version = cardreg_read_int(card->cid, CID_PRV_MMC);
                  date = cardreg_read_int(card->cid, CID_MDT_MMC);
                  month = date >> 4;
                  year = (date & 0xF) + 1997; // safe to 2012, bleurgh
                }
                else
                {
                  vendor = cardreg_lookup_manufacturer(cardreg_read_string(card->cid, CID_OID_SD, vendor_buf));
                  name = cardreg_read_string(card->cid, CID_PNM_SD, name_buf);
                  version = cardreg_read_int(card->cid, CID_PRV_SD);
                  date = cardreg_read_int(card->cid, CID_MDT_SD);
                  month = date & 0xF;
                  year = (date >> 4) + 2000; // safe to 2255
                }

                printf("%3u %3u  %04X  0  %-18s %11.11s  %-9.9s %-6.6s  %X.%X %u-%02u\n",
                    ctrl->bus,
                    sloti,
                    card->rca,
                    desc,
                    cap_buf,
                    vendor,
                    name,
                    version >> 4,
                    version & 0xF,
                    year,
                    month
                );
              }
            }
          }
          for (uint32_t function = 1; function <= slot->io_functions; function++)
          {
            intptr_t r1;
            const char *fic_name, *manf_name;
            char fic_name_buffer[32], description_buffer[32], manf_name_buffer[sizeof "xxxx"];
            _swix(OS_ServiceCall, _INR(0,1)|_OUTR(1,2), slot->fic[function-1], Service_SDIODescribeFIC, &r1, &fic_name);
            if (r1 != 0)
            {
              /* Nobody offered a name for the function */
              const char *format = message_lookup_direct("BadFIC");
              snprintf(fic_name_buffer, sizeof fic_name_buffer, format, slot->fic[function-1]);
              fic_name_buffer[sizeof fic_name_buffer - 1] = '\0';
              fic_name = fic_name_buffer;
            }
            snprintf(description_buffer, sizeof description_buffer, "%s %s", slot->io_product_info[function-1], fic_name);
            description_buffer[sizeof description_buffer - 1] = '\0';
            _swix(OS_ServiceCall, _INR(0,1)|_OUTR(1,2), slot->io_manf[function-1], Service_SDIODescribeMANF, &r1, &manf_name);
            if (r1 != 0)
            {
              /* Nobody offered a name for the manufacturer */
              sprintf(manf_name_buffer, "%04X", slot->io_manf[function-1]);
              manf_name = manf_name_buffer;
            }
            printf("%3u %3u  %04X%3u  %-30.30s  %-8.8s  %04X\n",
                ctrl->bus,
                sloti,
                slot->card[0].rca,
                function,
                description_buffer,
                manf_name,
                slot->io_card[function-1]
            );
          }
        }
        swi_Control_unlock(ctrl->bus, sloti);
      }
    }
  }

  return NULL;
}

_kernel_oserror *command_sdioslots(void)
{
  printf(message_lookup_direct("SDIOSltHdr"));
  printf("\n");

  for (ctrlnode_t *ctrl = g_ctrl; ctrl != NULL; ctrl = ctrl->next)
  {
    for (uint32_t sloti = 0; sloti < ctrl->dev->slots; sloti++)
    {
      sdmmcslot_t    *slot = ctrl->slot + sloti;
      if (swi_Control_lock(ctrl->bus, sloti) == NULL)
      {
        if (slot->card_detect_state == CD_ANNOUNCED)
        {
          printf("%3u %3u   %u.%u V   %u-bit  ",
              ctrl->bus,
              sloti,
              slot->voltage / 1000,
              (slot->voltage / 100) % 10,
              slot->lines
          );
          if (slot->freq < 1000)
            printf("%3u kHz %cDR\n", slot->freq, slot->ddr ? 'D' : 'S');
          else
            printf("%3u MHz %cDR\n", slot->freq / 1000, slot->ddr ? 'D' : 'S');
        }
        swi_Control_unlock(ctrl->bus, sloti);
      }
    }
  }

  return NULL;
}
