; > Version

        GET     VersionASM

        GBLA    Version
        GBLS    VString
        GBLS    SystemName
        GBLS    Date
        GBLA    OSVersionID

OSVersionID SETA &AA

Version SETA    531
VString SETS    "5.31"
SystemName SETS "RISC OS"
   [ (Version :AND: 1) = 1
Date    SETS    Module_Date      ; Odd-numbered (i.e. development) build, use
                                 ; date of last source check in
   |
Date    SETS    "27 Apr 2024"    ; version for RISC OS on desktop computers
                                 ; Desktop and Switcher use this via OS_Byte 0
   ]

        END
