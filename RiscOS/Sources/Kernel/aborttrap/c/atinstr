      }
    }
    for(int i=0;i<interleave;i++)
    {
      if (!aborttrap_vfp_d_write(ctx,d+r+inc*i,reg[i].d))
        return aborttrap_ERROR(BadReg);
    }
  }
  if (wback)
    aborttrap_reg_write_current(ctx,n,address + offset);
  bttf(ctx);
  return NULL;
}

