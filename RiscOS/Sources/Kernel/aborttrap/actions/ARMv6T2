# A8.6.77 LDRHT
LDRHT_A1(Rt,Rn,imm4H,imm4L,U)
{
	return aborttrap_LDRHT_imm(ctx,Rt,Rn,(imm4H<<4)|imm4L,true,U);
}

LDRHT_A2(Rt,Rn,Rm,U,nonstandard)
{
	if(nonstandard)
		return aborttrap_ERROR(Unexpected);
	return aborttrap_LDRHT_reg(ctx,Rt,Rn,Rm,true,U);
}

