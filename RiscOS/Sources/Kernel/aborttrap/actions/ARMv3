# A8.6.60 LDR (register)
LDR_reg_A1(Rt,Rn,imm5,type,Rm,P,U,W)
{
	eshift shift_t;
	uint32_t shift_n;
	decodeimmshift(type,imm5,&shift_t,&shift_n);
	return aborttrap_LDR_reg(ctx,Rt,Rn,Rm,P,U,!P || W,shift_t,shift_n);
}

