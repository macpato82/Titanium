/* Ported from assembler to C, 2026 (behaviour unchanged). */
/*
 * Module interface and application body for DisplayManager.
 *
 * Replaces s/Module and s/Front.  Contains:
 *   - the relocatable-module entry points (init / final / service / command);
 *   - the Wimp task lifecycle (Service_StartWimp offers the command, the command
 *     OS_Module Enter's us, main() runs the task) - cf. Desktop/WindowScroll;
 *   - the Wimp poll loop and its deferred-update handling (poll word);
 *   - shut-down, palette scanning and small shared helpers.
 *
 * Per the C-module rules, all persistent state lives in the global `g`
 * (relocated by the Shared C Library); the private word is never overwritten.
 */
#include <stdlib.h>
#include <string.h>
#include <stddef.h>

#include "kernel.h"
#include "swis.h"

#include "Global/RISCOS.h"
#include "Global/Services.h"
