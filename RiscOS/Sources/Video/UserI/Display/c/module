#include "Global/Variables.h"

#include "modhead.h"
#include "display.h"

/* Path variable and its default (was Mod_Path / Mod_PathDefault in s/Module). */
#define PATH_VAR      "DisplayManager$$Path"
#define PATH_DEFAULT  "Resources:$.Resources.Display."

/* The single persistent state block (was the s/Front workspace). */
display_state g;

/* Wimp messages we want delivered (was messages_list in s/Module). */
static const int messages_list[] = {
  Message_MenuWarning,
  Message_MenusDeleted,
  Message_HelpRequest,
#if OPT_LOADMODEFILES
  Message_DataLoad,
  Message_DataSave,
#endif
  0
};

/* ----------------------------------------------------------------------- *
 *  Palette scanning (was scanpalette in s/Module).
 *  Reads the current Wimp palette, compares the low 8 bits of each of the
 *  16 entries against the cached copy, updates the cache, and reports whether
 *  anything changed.
 * ----------------------------------------------------------------------- */
int scanpalette(void)
{
  int newpal[20];           /* Wimp_ReadPalette wants a 20-word block */
  unsigned char *cache = (unsigned char *)g.wimp_palette;
  int changed = 0;
  int i;

  if (_swix(Wimp_ReadPalette, _IN(1), newpal))
    return 0;

  for (i = 0; i < 16; i++)
  {
    unsigned char old = cache[i];
    unsigned char now = (unsigned char)newpal[i];
    cache[i] = now;
    if (now != old)
      changed = 1;
  }
  return changed;
}

