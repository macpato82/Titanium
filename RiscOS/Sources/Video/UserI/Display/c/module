 *  Deferred updates triggered by the poll word (was Mod_PollWord).
 * ----------------------------------------------------------------------- */
void mod_pollword(void)
{
  int pw = g.pollword;

  if (pw & pf_settitle)
  {
    /* TODO(step3): Window_SetTitle(); */
  }
  if (pw & pf_modeinit)
  {
    /* TODO(step4): Mode_Init(); */
  }
  if (pw & pf_refreshicons)
