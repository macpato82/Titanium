/* Ported from assembler to C, 2026 (behaviour unchanged). */
/*
 * Iconbar icon and display-window icon refresh (was s/Icon).
 */
#include <string.h>

#include "kernel.h"
#include "swis.h"

#include "display.h"
#include "wimpdefs.h"

/* The iconbar sprite icon: flags then sprite name (was icon_block in s/Icon). */
#define ICONBAR_ICON_FLAGS  0x00003002
#define ICONBAR_SPRITE      "display"

/* Wimp_CreateIcon block: window handle, bounding box, flags, 12 bytes of data. */
typedef struct {
  int  handle;
  int  x0, y0, x1, y1;
  int  flags;
  char data[12];
} create_icon_block;

/* Set an icon's state (was Icon_SetState). */
static _kernel_oserror *icon_setstate(int window, int icon, int eor, int clear)
{
  int block[4];
  block[0] = window;
  block[1] = icon;
  block[2] = eor;
  block[3] = clear;
  return _swix(Wimp_SetIconState, _IN(1), block);
}

/* Create the iconbar icon (was Icon_Init). */
_kernel_oserror *icon_init(void)
{
  _kernel_oserror *e;
  int wpx, hpx, mode;
  int eigx, eigy;
  create_icon_block blk;

  /* Read the sprite's pixel size and creation mode. */
  e = _swix(Wimp_SpriteOp, _IN(0) | _IN(2) | _OUT(3) | _OUT(4) | _OUT(6),
            SpriteReason_ReadSpriteSize, ICONBAR_SPRITE, &wpx, &hpx, &mode);
  if (e)
    return e;

  /* Convert pixel size to OS units via the mode's eigen factors. */
  _swix(OS_ReadModeVariable, _INR(0,1) | _OUT(2), mode, VduExt_XEigFactor, &eigx);
  _swix(OS_ReadModeVariable, _INR(0,1) | _OUT(2), mode, VduExt_YEigFactor, &eigy);

  blk.handle = -8;             /* iconbar, right-hand side, scan from right   */
  blk.x0 = 0;
  blk.y0 = 0;
  blk.x1 = wpx << eigx;
  blk.y1 = hpx << eigy;
  blk.flags = ICONBAR_ICON_FLAGS;
  memset(blk.data, 0, sizeof(blk.data));
  memcpy(blk.data, ICONBAR_SPRITE, sizeof(ICONBAR_SPRITE) - 1);

  e = _swix(Wimp_CreateIcon, _INR(0,1) | _OUT(0),
            WimpPriority_ModeChooser, &blk, &g.icon_handle);
  return e;
}

/* Get the Wimp to redraw the display window's colour/resolution/rate icons
 * (was Icon_Refresh). */
void icon_refresh(void)
{
  if (icon_setstate(g.display_handle, ic_display_colours, 0, 0))
    return;
  if (icon_setstate(g.display_handle, ic_display_resolution, 0, 0))
    return;
#if OPT_SELECTFRAMERATE
  icon_setstate(g.display_handle, ic_display_rate, 0, 0);
#endif
}
