;
; The single retained assembler routine of the C port of Hourglass.
;
; The TickerV handler (tickerv_handler in c/module) may be entered in IRQ mode
; by the CMunge vector veneer.  The per-frame pointer update calls SWIs
; (OS_Word / OS_Byte), which are unsafe in IRQ mode; the original assembler
; switched to SVC mode around that work.  C cannot switch processor mode, so
; this shim does it: switch to SVC, call the supplied C function, restore the
; entry mode.  (A no-op switch if the handler was already entered in SVC.)

        AREA    |Hourglass$$VeneerCode|, CODE, READONLY, PIC

        EXPORT  hg_call_in_svc

; void hg_call_in_svc(void (*fn)(void))
;   r0 = fn.  Calls fn() in SVC mode and returns to the caller's mode.
;   Only r0-r3 and lr (all APCS caller-saved) are used, so r4-r11, the static
;   base and the stack pointer are preserved and fn sees the C environment set
;   up by the CMunge veneer.

hg_call_in_svc
        MOV     r1, lr                  ; r1 = return address (lr is mode-banked)
        MRS     r2, CPSR                ; r2 = caller PSR (to restore the mode)
        MOV     r3, r0                  ; r3 = fn
        BIC     r0, r2, #0x1F           ; build the SVC PSR: clear the mode bits,
        ORR     r0, r0, #0x13           ;   select SVC (keep the I/F/T flags)
        MSR     CPSR_c, r0              ; switch to SVC mode
        STMFD   sp!, {r1, r2, lr}       ; save retaddr, caller PSR, SVC lr
        MOV     lr, pc                  ; return address for the call below
        MOV     pc, r3                  ; fn()
        LDMFD   sp!, {r1, r2, lr}       ; restore
        MSR     CPSR_c, r2              ; switch back to the caller's mode
        MOV     pc, r1                  ; return to the caller

        END
