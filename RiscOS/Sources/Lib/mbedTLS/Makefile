COMPONENT  = mbedTLS
OBJS_X509  = pkcs7 x509 \
             x509_create x509_crl x509_crt \
             x509_csr x509write x509write_crt x509write_csr
OBJS_TLS =   debug mps_reader mps_trace net_sockets \
             ssl_cache ssl_ciphersuites ssl_client \
             ssl_cookie ssl_debug_helpers_generated ssl_msg ssl_ticket \
             ssl_tls \
             ssl_tls12_client ssl_tls12_server \
             ssl_tls13_keys ssl_tls13_client ssl_tls13_server ssl_tls13_generic
OBJS_CRYPTO = aes aesce aesni aria \
             asn1parse asn1write base64 \
             bignum bignum_core bignum_mod bignum_mod_raw block_cipher \
             camellia ccm chacha20 chachapoly cipher cipher_wrap cmac \
             constant_time ctr_drbg des dhm \
             ecdh ecdsa ecjpake \
             ecp ecp_curves ecp_curves_new \
             entropy entropy_poll \
             error gcm \
             hkdf hmac_drbg lmots lms md md5 \
             memory_buffer_alloc nist_kw oid \
             padlock pem pk \
             pk_wrap pk_ecc pkcs12 pkcs5 \
             pkparse pkwrite platform platform_util \
             poly1305 ripemd160 rsa rsa_alt_helpers sha1 sha3 \
             sha256 sha512 threading timing \
             version version_features
OBJS_PSA   = psa_crypto psa_crypto_aead psa_crypto_cipher psa_crypto_client \
             psa_crypto_driver_wrappers_no_static psa_crypto_ecp psa_crypto_ffdh \
             psa_crypto_hash psa_crypto_mac psa_crypto_pake psa_crypto_rsa psa_crypto_random \
             psa_crypto_se psa_crypto_slot_management psa_crypto_storage \
             psa_its_file psa_util
OBJS       = ${OBJS_X509} ${OBJS_TLS} ${OBJS_CRYPTO} ${OBJS_PSA}
HDRS       = ro_config ro_crypto_config other_mbedtls_hdrs
CINCLUDES  = ${TCPIPINC}
CDEFINES   = -DMBEDTLS_CONFIG_FILE="\"ro_config.h\"" -DRISCOS
CFLAGS     = ${C_NOWARN_NON_ANSI_INCLUDES} ${C_NOWARN_UNDEF_HASHIF}
SOURCES_TO_SYMLINK = $(wildcard mbedtls/h/*) $(wildcard psa/h/*)

include CLibrary

ifeq (,${MAKE_VERSION})

# RISC OS / amu case

exphdr.ro_config:
	${AWK} -f h.ro_configawk h.ro_config > ${EXPDIR}.h.ro_config

else

# Posix / gmake case

ro_config.exphdr:
	${AWK} -f ro_configawk.h ro_config.h > ${EXPDIR}/ro_config.h

endif

other_mbedtls_hdrs.exphdr:
	${CP} mbedtls ${EXPDIR}${SEP}mbedtls ${CPFLAGS}
	${CP} psa     ${EXPDIR}${SEP}psa     ${CPFLAGS}

