# Makefile for SyncLib

COMPONENT   = SyncLib
HDRS        = atomic barrier cpuevent               mutex spin spinrw synclib
OBJS        = atomic barrier cpuevent cpuflags init mutex spin spinrw
SOURCES_TO_SYMLINK = $(wildcard hdr/*)

LIBRARIES = ${LIBRARY} ${LIBRARYZM}
# Enable the HAL+kernel build configs if the machine/build type supports it
ifeq (,$(filter ${MACHINE},Disc 32 All All32))
LIBRARIES += ${LIBRARYK} ${LIBRARYH}
endif

include CLibrary

