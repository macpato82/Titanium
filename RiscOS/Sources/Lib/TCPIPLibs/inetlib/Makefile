ifeq ($(filter install%,${MAKECMDGOALS}),)
EXPDIR    = ${LIBDIR}${SEP}TCPIPLibs
else
EXPDIR    = ${INSTDIR}${SEP}TCPIPLibs
endif
CINCLUDES = ${TCPIPINC}
CDEFINES  = -DINET
CFLAGS    = ${C_NOWARN_ASSIGNMENT_AS_CONDITION} ${C_NOWARN_NON_ANSI_INCLUDES}
