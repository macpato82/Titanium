/*
 * Rpc additions to <sys/types.h>
 */
#ifndef __TYPES_RPC_HEADER__
#define __TYPES_RPC_HEADER__

#define	bool_t	int
#define	enum_t	int
#define	FALSE	(0)
#define	TRUE	(1)
#define __dontcare__	-1
#ifndef NULL
#	define NULL 0
#endif

#ifdef __STDC__
#include <stdlib.h>
#include <stdio.h>
#else
#ifndef RISCOS
extern char *malloc();
#endif
#endif

#ifdef __riscos
#  ifdef __cplusplus
  extern "C" {
#  endif
#  include <stdio.h>
extern void *_rpclib_malloc(size_t);
extern void _rpclib_free(void *);
#  ifdef __cplusplus
  }
#  endif
#  define mem_alloc(bsize)      _rpclib_malloc(bsize)
#  define mem_free(ptr, bsize)  _rpclib_free(ptr)
#else
#define mem_alloc(bsize)	malloc(bsize)
#define mem_free(ptr, bsize)	free(ptr)
#endif

#ifndef makedev /* ie, we haven't already included it */
#include <sys/types.h>
#endif
#include <sys/time.h>

#ifndef __riscos
#ifndef INADDR_LOOPBACK
#define       INADDR_LOOPBACK         (u_long)0x7F000001
#endif
#endif
#ifndef MAXHOSTNAMELEN
#define        MAXHOSTNAMELEN  64
#endif

#endif /* ndef __TYPES_RPC_HEADER__ */
