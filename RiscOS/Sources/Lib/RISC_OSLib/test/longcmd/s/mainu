        ; You'll often see these prefixed with Hdr: for historic reasons.
        ; This is no longer necessary, and in fact omitting them makes it
        ; possible to cross-compile your source code.
        GET     ListOpts
        GET     Macros
        GET     System
        GET     DDEUtils

        AREA    |!!!|, CODE, READONLY, PIC

        IMPORT  __RelocCode
        IMPORT  mainu

        EXPORT  __main
        EXPORT  ddeutils_setclsize
        EXPORT  ddeutils_setcl
        EXPORT  ddeutils_flushcl

        ENTRY

__main
        ; Main entry point
        ; Called with:
        ; R0 = command line
        ; R1 = command line tail
        ; R12 = 1K workspace
        ; R13 = workspace end & SP
        ; R14 = return address
        STMFD   R13!,{R0,R1,R14}
        BL      __RelocCode ; Corrupts fp
        LDMFD   R13!,{R0,R1}
        MOV     R11,#0
        BL      mainu
        CMP     R0,#0
        SETV    NE
        LDR     PC,[R13],#4

ddeutils_setclsize
        SWI     XDDEUtils_SetCLSize
        MOVVC   r0, #0
        MOV     pc, lr

ddeutils_setcl
        SWI     XDDEUtils_SetCL
        MOVVC   r0, #0
        MOV     pc, lr

ddeutils_flushcl
        SWI     XDDEUtils_FlushCL
        MOVVC   r0, #0
        MOV     pc, lr

        END
