void module_service(int service_number, _kernel_swi_regs *r, void *pw)
{
	(void) pw;

	switch(service_number)
	{
	case Service_Memory:
		/* Don't let the Wimp take back our wimp slot */
		if(r->r[2] == (int)Image_RO_Base)
			r->r[1] = 0;
		break;
	}
}
