/* Test handling of long command lines */
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include "kernel.h"
#include "swis.h"

static void sub(const char *self,int len,int sum,const char *text)
{
	if (strlen(text) != len)
	{
		fprintf(stderr,"Incorrect command line length: expected %d chars but got %d\n",len,strlen(text));
		return; /* main() will print out the args for debugging */
	}
	int crc = _swi(OS_CRC,_INR(0,3),0,text,text+len,1);
	if (crc != sum)
	{
		fprintf(stderr,"Incorrect command line CRC: expected %d but got %d\n",sum,crc);
		return; /* main() will print out the args for debugging */
	}
	printf("sub %s %d OK\n",self,len);
	exit(EXIT_SUCCESS);
}

#define MAXLEN 0x20000

static void test(const char *self,int len,char *buf)
{
	printf("%d\n",len);
	char *crcstr = buf + sprintf(buf,"%s --sub %d ",self,len);
	char *text = crcstr + 8;
	for(int i=0;i<len;i++)
	{
		text[i] = (rand() & 0xf) + 'a';
	}
	text[len] = 0;
	int crc = _swi(OS_CRC,_INR(0,3),0,text,text+len,1);
	crcstr += sprintf(crcstr,"%d",crc);
	while (crcstr < text)
	{
		*crcstr++ = ' ';
	}
	_kernel_last_oserror(); /* Clear any previous cached error */
	int status = system(buf);
	_kernel_oserror *e = _kernel_last_oserror();
	_kernel_oserror last;
	if (e != NULL)
	{
		memcpy(&last,e,sizeof(last));
	}
	/* Consider an OS error to be a failure, apart from SWI not known, which could be DDEUtils being missing (if DDEUtils is missing we should get another failure once we actually hit the kernel cmdline limit), and "Uncaught trap: Not enough memory for C library" (which will be used if the child runs out of free app space during initialisation) */
	if ((status != EXIT_SUCCESS) || (e != NULL))
	{
		if ((e != NULL) && ((last.errnum == 0x1E6) || (last.errnum == 0x800e01)))
		{
			printf("Acceptable failure: Error %08x %s\n",last.errnum,last.errmess);
			return;
		}
		fprintf(stderr,"Failed (status %d)\n",status);
		if (e != NULL)
		{
			fprintf(stderr,"Error %08x %s\n",last.errnum,last.errmess);
		}
		fprintf(stderr,"len = %d\ncrc = %d\ntext = %s\n",len,crc,text);
		exit(EXIT_FAILURE);
	}
}

static void run(const char *self)
{
	char *buf = malloc(MAXLEN + 64 + strlen(self));
	for(int len=64;len<MAXLEN;len+=64)
	{
		test(self,len,buf);
	}
	exit(EXIT_SUCCESS);
}

int main(int argc,char **argv)
{
	if ((argc == 1) || !strcmp(argv[1],"-h") || !strcmp(argv[1],"--help") || !strcmp(argv[1],"help"))
	{
		fprintf(stderr,"usage: longcmd --run [<target>]\nTest long command line handling\n");
		return EXIT_FAILURE; /* Return with a failure code here, just in case we accidentally end up here when running as a child process */
	}
	else if (!strcmp(argv[1],"--run"))
	{
		run((argc>2) ? argv[2] : argv[0]);
	}
	else if (!strcmp(argv[1],"--sub") && (argc == 5))
	{
		sub(argv[0],atoi(argv[2]),atoi(argv[3]),argv[4]);
	}
	fprintf(stderr,"Invalid arguments, try --help for help\n");
	for(int i=0;i<argc;i++)
	{
		fprintf(stderr,"argv[%d] = %s\n",i,argv[i]);
	}
	return EXIT_FAILURE;
}
