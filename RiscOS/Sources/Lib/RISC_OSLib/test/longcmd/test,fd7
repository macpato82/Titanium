| Test long command line handling by Absolute files
X ChangeDynamicArea -RamFSSize 1M
Copy <Obey$Dir>.LongCmd RAM::0.$.LongCmd ~CF

| Test small wimpslots
Wimpslot -max 200K
echo Testing child apps with small initial wimpslots
run RAM::0.$.LongCmd --run
if "<sys$returncode>"<>"0" then obey

| Test large wimpslots
Wimpslot -min 640K -max 640K
echo Testing child apps with large initial wimpslots
run RAM::0.$.LongCmd --run
if "<sys$returncode>"<>"0" then obey

echo Done
