#include <stdio.h>
#include "kernel.h"

extern void otherfile1_ctor(void);
extern void otherfile1_dtor(void);
extern void mylib_import(void);

static void test(const char *name, void (*fn)(void))
{
  const char *lang = _kernel_language((int) fn);
  if (lang)
    printf("%s language is '%s'\n", name, lang);
  else
    printf("%s language is unknown\n", name);
}

#define TEST(fn) do { test(#fn, fn); } while (0)

int main(void)
{
  mylib_import();
  printf("In main\n");
  TEST(otherfile1_ctor);
  TEST(otherfile1_dtor);
}
