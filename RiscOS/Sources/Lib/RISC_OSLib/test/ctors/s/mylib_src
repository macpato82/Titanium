        IMPORT   |_printf|
        EXPORT   |mylib_import|

        AREA     |C$$ctorvec|, DATA, READONLY

        &        |mylib_ctor|

        AREA     |C$$ctor|, CODE, READONLY

|mylib_ctor| ROUT
        ADR      r0,%F01
        B        |_printf|
01      =        "In mylib constructor", 10, 0
        ALIGN

        AREA     |C$$dtorvec|, DATA, READONLY

        &        |mylib_dtor|

        AREA     |C$$dtor|, CODE, READONLY

|mylib_dtor| ROUT
        ADR      r0,%F01
        B        |_printf|
01      =        "In mylib destructor", 10, 0
        ALIGN

        AREA     |C$$code|, CODE, READONLY

|mylib_import| ROUT
        MOV      pc,lr

        END
