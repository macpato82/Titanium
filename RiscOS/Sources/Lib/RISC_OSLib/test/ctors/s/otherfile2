        IMPORT   |_printf|

        AREA     |C$$ctorvec|, DATA, READONLY

        &        |otherfile2_ctor|

        AREA     |C$$ctor|, CODE, READONLY

|otherfile2_ctor| ROUT
        ADR      r0,%F01
        B        |_printf|
01      =        "In otherfile2 constructor", 10, 0
        ALIGN

        AREA     |C$$dtorvec|, DATA, READONLY

        &        |otherfile2_dtor|

        AREA     |C$$dtor|, CODE, READONLY

|otherfile2_dtor| ROUT
        ADR      r0, %F01
        B        |_printf|
01      =        "In otherfile2 destructor", 10, 0
        ALIGN

        END
