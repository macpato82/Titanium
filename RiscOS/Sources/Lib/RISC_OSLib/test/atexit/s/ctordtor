        GET      Hdr:ListOpts
        GET      Hdr:Macros
        GET      Hdr:System

        AREA     |C$$ctorvec|, DATA, READONLY

        &        |ctor|

        AREA     |C$$ctor|, CODE, READONLY

|ctor| ROUT
        Push     "lr"
        ADR      r0, %F01
        SWI      XOS_Write0
        Pull     "pc"

01      =        "In constructor", 10, 13, 0
        ALIGN

        AREA     |C$$dtorvec|, DATA, READONLY

        &        |dtor|

        AREA     |C$$dtor|, CODE, READONLY

|dtor| ROUT
        Push     "lr"
        ADR      r0, %F01
        SWI      XOS_Write0
        Pull     "pc"

01      =        "In destructor", 10, 13, 0
        ALIGN

        END
