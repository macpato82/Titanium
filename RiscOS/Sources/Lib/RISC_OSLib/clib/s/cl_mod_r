; -*- Mode: Assembler -*-
;* Lastedit: 22 Feb 90 16:06:44 by Harry Meekings *
; driver code to call _main for NorCroft C system.
; Version to sit on top of shared library kernel
;
; Copyright (C) Acorn Computers Ltd., 1988.
;

        GBLL    Brazil_Compatible
        GBLS    Calling_Standard
        GBLL    ModeMayBeNonUser
        GBLL    SharedLibrary

Brazil_Compatible  SETL  {FALSE}
Calling_Standard   SETS  "APCS_U"
ModeMayBeNonUser   SETL  {TRUE}
SharedLibrary      SETL  {TRUE}

        GET     h_regs.s
        GET     h_brazil.s
        GET     h_modmacro.s

        Module CLib

        AREA    |C$$data|

StaticData
dataStart
        GET     clib/cl_data.s

        AREA    |Lib$$Init|, READONLY

        IMPORT  |CLib_data_end|
        &       2
        &       entriesStart
        &       entriesEnd
        &       dataStart
        &       |CLib_data_end|

        &       5
        &       entries2Start
        &       entries2End
        &       0
        &       0

        &       7
        &       entries3Start
        &       entries3End
        &       0
        &       0

        &       8
        &       entries4Start
        &       entries4End
        &       0
        &       0

        &       9
        &       entries5Start
        &       entries5End
        &       0
        &       0


        AREA    |RTSK$$Data|, READONLY
        IMPORT  |C$$code$$Base|
        IMPORT  |C$$code$$Limit|
        IMPORT  |C$$ctor$$Base|, WEAK
        IMPORT  |C$$ctor$$Limit|, WEAK
        IMPORT  |C$$dtor$$Base|, WEAK
        IMPORT  |C$$dtor$$Limit|, WEAK
        IMPORT  |C$$ctorvec$$Base|, WEAK
        IMPORT  |C$$ctorvec$$Limit|, WEAK
        IMPORT  |C$$dtorvec$$Base|, WEAK
        IMPORT  |C$$dtorvec$$Limit|, WEAK

        &       EndRTSK-.
        &       |C$$code$$Base|
        &       |C$$code$$Limit|
        &       CLanguageString
        &       0               ; No initialisation
        &       Finalise        ; finalisation
        &       TrapHandler
        &       UncaughtTrapHandler
        &       EventHandler
        &       UnhandledEventHandler
        &       0               ; No FastEventProc handler
        &       0               ; No UnwindProc handler
        &       0               ; No NameProc handler
        &       |C$$ctor$$Base|
        &       |C$$ctor$$Limit|
        &       |C$$dtor$$Base|
        &       |C$$dtor$$Limit|
        &       |C$$ctorvec$$Base|
        &       |C$$ctorvec$$Limit|
        &       |C$$dtorvec$$Base|
        &       |C$$dtorvec$$Limit|
        ; Note: with the shared C library, the stub contains no finalisation
        ; but the library does.  (and the kernel does library as well as
        ; client finalisation).  It needs to be this way rather than the
        ; obvious stub containing finalisation because early versions of the
        ; C library had none.
EndRTSK

        AREA    |C$$code|, CODE, READONLY

entriesStart
        ; For compatibility with old clients, this chunk contains both the original set of entries (cl_entries) and the entries that were moved to a new chunk (cl_entry1x)
        GET     clib/cl_entries.s
        GET     clib/cl_entry1x.s
entriesEnd

entries2Start
        ; The 'entries2' chunk contains both the original entries (cl_entry2) and the entries that were moved to a new chunk (cl_entry2x)
        GET     clib/cl_entry2.s
        GET     clib/cl_entry2x.s
entries2End

entries3Start
        GET     clib/cl_entry3.s
entries3End

entries4Start
        GET     clib/cl_entry4.s
entries4End

entries5Start
        GET     clib/cl_entry5.s
entries5End

        EXPORT  |__main|
        ; The compiler produces references to this, so it must be defined,
        ; but it had better not be branched to.
|__main|
        DCI     &E7FFFFFF       ; In illegal instruction space
CLanguageString = "C",0
        ALIGN

        LNK     clib/cl_body.s
