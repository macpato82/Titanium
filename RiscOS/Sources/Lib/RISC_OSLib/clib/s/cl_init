       AREA    |RTSK$$Data|, READONLY
        IMPORT  |C$$code$$Base|
        IMPORT  |C$$code$$Limit|
        IMPORT  |C$$ctor$$Base|, WEAK
        IMPORT  |C$$ctor$$Limit|, WEAK
        IMPORT  |C$$dtor$$Base|, WEAK
        IMPORT  |C$$dtor$$Limit|, WEAK
        IMPORT  |C$$ctorvec$$Base|, WEAK
        IMPORT  |C$$ctorvec$$Limit|, WEAK
        IMPORT  |C$$dtorvec$$Base|, WEAK
        IMPORT  |C$$dtorvec$$Limit|, WEAK

 [ ModeMayBeNonUser
        EXPORT  |__rtskBase|
 ]

|__rtskBase|
        &       EndRTSK-.
        &       |C$$code$$Base|
        &       |C$$code$$Limit|
        &       CLanguageString
        &       Initialise
 [ SharedLibrary
        &       0       ; compatibility - sharedlibrary here means stub
 |
        &       Finalise
 ]
        &       TrapHandler
        &       UncaughtTrapHandler
        &       EventHandler
        &       UnhandledEventHandler
        &       0               ; No FastEventProc handler
        &       0               ; No UnwindProc handler
        &       0               ; No NameProc handler
        &       |C$$ctor$$Base|
        &       |C$$ctor$$Limit|
        &       |C$$dtor$$Base|
        &       |C$$dtor$$Limit|
        &       |C$$ctorvec$$Base|
        &       |C$$ctorvec$$Limit|
        &       |C$$dtorvec$$Base|
        &       |C$$dtorvec$$Limit|
EndRTSK

        AREA    |C$$code|, CODE, READONLY
        IMPORT  main, WEAK
        EXPORT  |__main|

CLanguageString
        =       "C",0
        ALIGN

; __main is a dummy definition to statisfy references generated by the
; compiler. It should never be called.
|__main|

Initialise
        ; If the SharedCLibrary is new enough that _clib_initialise looks for
        ; an argument (a pointer to a language description block) then it's
        ; also new enough that the SharedCLibrary kernel will have called
        ; InitProcs such as ourselves with that pointer already in a1.

 [ SharedLibrary
; Here, SharedLibrary means stub. In this case, we have to enable Wimp-Slot
; extension by _kernel_alloc, as for compatibility with old binaries it has
; to be off by default.
        LDR     a3, =StaticData + 0x115 ; aka |O_kallocExtendsWS|
; 0x115 is the historic location of the variable, at least as far back as
; CLib 3.99 (RISC OS 3.11). Check that the offset is still correct for this
; build of CLib, since modern versions of CLib still rely on it being poked by
; the stubs in order to enable slot extension.
        ASSERT  |_stub_kallocExtendsWS|-StaticData = 0x115
        LDR     a2, [sl, #SL_Client_Offset]
        ADD     a3, a3, a2
        MOV     a2, #1
        STRB    a2, [a3]                ; enable new _kernel_alloc behaviour
 ]
        FunctionEntry
        BL      |_clib_initialise|
        LDR     a1, =main
        CMP     a1, #0
        ADRNE   a1, RunSubMain
        Return

RunSubMain
; args for _main(): command line
;                   address of main
        FunctionEntry "", makeframe
        BL      |_kernel_command_string|
        LDR     a2, =main
        BL      |_main|
; Doesn't return, but just in case...
        Return  "", fpbased

        END
