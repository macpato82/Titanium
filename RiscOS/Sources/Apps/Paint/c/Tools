 *  The Brush tool   *
 *********************/

/* This will hold an additional sprite with the current brush stroke when *
 * opacity is below the maximum. It will be plotted translucently over    *
 * the base sprite when the sprite window is redrawn.                     *
 * It's necessary to avoid interference patterns where the brush sprite   *
 * overlaps previous plots of itself.                                     */
main_file layersfile = {NULL, NULL, NULL, NULL, ~0, ~0, 0, 0, 1, 0, NULL};
tools_layer toolslayer = {NULL, NULL, FALSE};

/* Gets a sprite used as an additional layer, currently only used *
 * internally to contain any translucent brush stroke.            */
main_sprite *tools_get_layer (main_sprite *basesprite)

{
  ftracef0 ("tools_get_layer\n");
  if (toolslayer.basesprite != basesprite)
    return NULL;
  return toolslayer.layersprite;
}

/* Gets a translation table suitable for plotting the layer directly *
 * onto the screen, currently used to render translucent brush       *
 * strokes while the mouse button is held down.                      */
main_ttab *tools_get_layer_screen_transtab (main_sprite *basesprite)

{
  ftracef0 ("tools_get_layer_screen_transtab\n");
  if (toolslayer.basesprite != basesprite || toolslayer.layersprite == NULL)
  {
    ftracef0 ("toolslayer is for different base sprite. Returning NULL.\n");
    return NULL;
  }

  if (toolslayer.screentranstab == NULL &&
      (bbc_modevar (psprite_address (toolslayer.layersprite)->mode, bbc_Log2BPP) != -1))
  {
    toolslayer.screentranstab = psprite_ttab_for_sprite (toolslayer.layersprite,
                                                         -1, (int *) -1, 0, 0);
    if (toolslayer.screentranstab == NULL)
      wimpt_noerr (main_error ("PntEG"));
    else
      ftracef2 ("Made layer to screen ttab: %x refcount %d\n",
          toolslayer.screentranstab, toolslayer.screentranstab->refcount);
  }
  return toolslayer.screentranstab;
}

os_error *tools_make_brushmouse_sprite (void)

{
  sprite_info sid;
  os_error *error = NULL;
  main_window dummywin;
  main_info_block dummyblock;
  wimp_box region;
  int flags;
  int space_needed = 0;
  sprite_header *addr;
  sprite_area *sarea;
  main_sprite *s;

  ftracef0 ("tools_make_brushmouse_sprite\n");
  tools_get_sprite_info_pixels (tools_brushsprite_ptr, &sid);
  region.x0 = 0;
  region.y0 = 0;
  region.x1 = (sid.width - 1) * tools_brushsprite_ptr->mode.scale_xmul;
  region.y1 = (sid.height - 1) * tools_brushsprite_ptr->mode.scale_ymul;

  tools_brushfile.sprites = m_ALLOC(sizeof (main_sprite));
  if (tools_brushfile.sprites == NULL)
  {
    /* Don't display error box to user here. Caller will handle this. */
    ftracef0 ("Error: Insufficient memory to make brush sprite copy.\n");
    error = main_error ("PntWG");
    goto finish;
  }

  s = tools_brushfile.sprites;
  s->link         = NULL;
  s->file         = &tools_brushfile;
  s->windows      = NULL;
  s->offset       = 0;
  s->spriteno     = 0;
  s->transtab     = tools_brushsprite_ptr->transtab;
  s->colourhandle = 0;
  s->bgcolourhandle = 0;
  s->gcol.colour  = tools_brushsprite_ptr->gcol.colour;
  s->gcol.alpha   = 255;
  s->gcol.ecf     = FALSE;
  s->flags        = 0;
  s->gcol2.colour = 0;
  s->gcol2.alpha  = 255;
  s->gcol2.ecf    = FALSE;
  s->mode.scale_xmul = tools_brushsprite_ptr->mode.scale_xmul;
  s->mode.scale_xdiv = tools_brushsprite_ptr->mode.scale_xdiv;
  s->mode.scale_ymul = tools_brushsprite_ptr->mode.scale_ymul;
  s->mode.scale_ydiv = tools_brushsprite_ptr->mode.scale_ydiv;
  memset (s->toolspace, 0, sizeof (s->toolspace));
  memset (&dummywin, 0, sizeof (dummywin));
  memset (&dummyblock.sprite, 0, sizeof (dummyblock.sprite));
  dummyblock.sprite.sprite = tools_brushsprite_ptr;
  dummywin.data = &dummyblock;

  make_temporary_sprite (&dummywin, region, tools_brushfile.sprites, &tools_brushfile,
      "brushmouse", FALSE, FALSE, FALSE);

  flags = 1;/* Cuttoff value of 1. Bit 30-31 are zero to convert to on-off mask */
  ftracef0 ("About to convert to on/off mask.\n");
  sarea = tools_brushfile.spritearea;
  space_needed = sid.height * (sid.width + 31 >> 5 << 2);
  menus_ensure_size (&tools_brushfile.spritearea, space_needed);
  addr = psprite_address (tools_brushfile.sprites);
  error = os_swix4r (OS_SpriteOp, SpriteReason_CreateRemoveAlpha | 0x200, (int)sarea, (int)addr, flags,
                                  NULL, NULL, NULL, &space_needed);
  if (error != NULL)
  {
    /* If r3 > 0 it will give amount of extra space needed in area */
    if (space_needed > 0)
      ftracef1 ("More space needed for alpha conversion: %d\n", space_needed);
    ftracef2 ("Error %d %s\n", error->errnum, error->errmess);
    if (error->errnum == 133)
      wimpt_complain (main_error ("PntEG"));
    tools_delete_brushmouse_sprite ();
    goto finish;
  }
  ftracef0 ("Alpha conversion succeeded.\n");
  tools_brushmouse_ptr = tools_brushfile.sprites;

  finish:
  if (error != NULL)
  {
    tools_brushmouse_ptr = NULL;
    menus_ensure_size (&tools_brushfile.spritearea, 0);
  }
  return error;
}

void tools_delete_brushmouse_sprite (void)

{
  ftracef0 ("tools_delete_brushmouse_sprite\n");
  if (tools_brushfile.sprites == NULL)
  {
    ftracef0 ("Nothing to delete!\n");
    return;
  }

  /* The brush transtab currently is reused from the main brush sprite
     so doesn't need to be deleted here */

  /* Note that this deletes the entire sprite area currently. */
  delete_temporary_sprite (tools_brushfile.sprites, &tools_brushfile);

  if (tools_brushfile.sprites != NULL)
  {
    m_FREE(tools_brushfile.sprites, sizeof (main_sprite));
    tools_brushfile.sprites = NULL;
  }
  tools_brushfile.spritearea = NULL;
  tools_brushmouse_ptr = NULL;
}

/* Makes a sprite used as an additional layer, currently only used       *
 * internally to contain any translucent brush stroke.                   *
 * The layer's intitialised with a copy of the supplied sprite, to       *
 * support brushes with alpha masks so any blended pixels will be the    *
 * correct colour. The layer's mask will be cleared to all transparent.  */
main_sprite *tools_create_layer (main_window *window)

{
  main_sprite *sprite;
  os_error *error = NULL;
  BOOL madeSprite = FALSE;
  if (window == NULL || window->data == NULL || window->data->sprite.sprite == NULL)
  {
    ftracef0 ("window, window->data or window->data->sprite.sprite are NULL in tools_create_layer!\n");
    return NULL;
  }
  sprite = window->data->sprite.sprite;
  ftracef0 ("tools_create_layer\n");

  if (layersfile.sprites == NULL)
  {
    sprite_info sid;
    wimp_box region;
    tools_get_sprite_info_pixels (sprite, &sid);
    region.x0 = 0;
    region.y0 = 0;
    region.x1 = tools_pixel_to_point_x (&window->data->sprite,
        sid.width - 1);
    region.y1 = tools_pixel_to_point_y (&window->data->sprite,
        sid.height - 1);

    layersfile.sprites = m_ALLOC(sizeof (main_sprite));
    if (layersfile.sprites == NULL)
    {
      /* Don't display error box to user here. Caller will handle this. */
      ftracef0 ("Error: Insufficient memory to make layer sprite.\n");
      goto finish;
    }
    else
    {
      static int *palette = NULL;
      main_sprite *s = layersfile.sprites;

      s->link         = NULL;
      s->file         = &layersfile;
      s->windows      = NULL;
      s->offset       = 0;
      s->spriteno     = 0;
      s->transtab     = NULL;
      s->colourhandle = 0;
      s->bgcolourhandle = 0;
      s->gcol.colour  = sprite->gcol.colour;
      s->gcol.alpha   = 255;
      s->gcol.ecf     = FALSE;
      s->flags        = 0;
      s->gcol2.colour = 0;
      s->gcol2.alpha  = 255;
      s->gcol2.ecf    = FALSE;
      s->mode.scale_xmul = sprite->mode.scale_xmul;
      s->mode.scale_xdiv = sprite->mode.scale_xdiv;
      s->mode.scale_ymul = sprite->mode.scale_ymul;
      s->mode.scale_ydiv = sprite->mode.scale_ydiv;
      memset (s->toolspace, 0, sizeof (s->toolspace));

      make_temporary_sprite (window, region, layersfile.sprites, &layersfile,
        "brushlayer0", /*Force a mask*/TRUE, /*Force a palette*/TRUE,
        /*Clear to transparent*/TRUE);
      madeSprite = TRUE;

      /* Get a translation table */
      /*Get the palette of the destination sprite.*/
      if ((error = psprite_build_palette (layersfile.sprites, &palette)) != NULL)
       goto finish;
      ftracef0 ("calling psprite_ttab_for_sprite()\n");
      if ((s->transtab = psprite_ttab_for_sprite
          (s, psprite_address (sprite)->mode,
          palette != NULL? palette: (int *) -1, 0, 0)) == NULL)
      {
        error = main_error ("PntEG");
        goto finish;
      }
    }
    toolslayer.basesprite = sprite;
    toolslayer.layersprite = layersfile.sprites;
  }

  finish:
  if (error != NULL)
  {
    ftracef0 (error->errmess);
    if (madeSprite)
      delete_temporary_sprite (layersfile.sprites, &layersfile);
    if (layersfile.sprites != NULL)
      m_FREE (layersfile.sprites, sizeof (main_sprite));
    layersfile.sprites = NULL;
    toolslayer.basesprite = NULL;
    toolslayer.layersprite = NULL;
  }
  toolslayer.screentranstab = NULL;
  return layersfile.sprites;
}

void tools_delete_layer (void)

{
  ftracef0 ("tools_delete_layer\n");
  if (layersfile.sprites == NULL)
  {
    ftracef0 ("Nothing to delete!\n");
    toolslayer.basesprite = NULL;
    toolslayer.layersprite = NULL;
    return;
  }
  /* Free any brush translation table */
  ftracef0 ("Dropping translucent layer translation tables\n");
  if (toolwindow_current_tool == &tools_brushpaint)
  {
    ftracef2 ("layersfile.sprites->toolspace[2] ttab: %x refcount %d\n", layersfile.sprites->toolspace [2], (layersfile.sprites->toolspace [2])?((main_ttab *)layersfile.sprites->toolspace [2])->refcount:0);
    psprite_drop_translation ((main_ttab **) &layersfile.sprites->toolspace [2]);
  }
  ftracef2 ("layersfile.sprites->transtab: %x refcount: %d\n", layersfile.sprites->transtab, layersfile.sprites->transtab->refcount);

  /* Free normal translation table */
  psprite_drop_translation (&layersfile.sprites->transtab);

  /* Free translation table for plotting layer to screen */
  ftracef2 ("toolslayer.screentranstab: %x refcount: %d\n", toolslayer.screentranstab, toolslayer.screentranstab->refcount);
  psprite_drop_translation (&toolslayer.screentranstab);

  /* Note that if we ever want to support multiple layers, this deletes
     the entire sprite area currently. */
  delete_temporary_sprite (layersfile.sprites, &layersfile);

  if (layersfile.sprites != NULL)
  {
    m_FREE(layersfile.sprites, sizeof (main_sprite));
    layersfile.sprites = NULL;
  }
  layersfile.spritearea = NULL;
  toolslayer.basesprite = NULL;
  toolslayer.layersprite = NULL;
  toolslayer.mergepending = FALSE;
}

void tools_merge_layer_onto (main_sprite *sprite)

{
  ftracef0 ("tools_merge_layer_onto\n");
  /* If the brush stroke's in a translucent layer, merge that onto
     the underlying sprite now. */
  main_sprite *translucentlayer = tools_get_layer (sprite);
  if (translucentlayer != NULL && toolslayer.mergepending)
  {
    os_error *err = NULL;
    main_scaling_block scale = {1, 1, 1, 1};
    unsigned char translucency = 255 - (unsigned char)translucentlayer->gcol.alpha;
    BOOL addpal;
    int oldoffset = 0;

    /* Now set dest mode pixel sizes. */
    /* We don't need to restore the existing values as we're going to   *
     * delete the layer, otherwise they'd need copying and putting back *
     * like brushpaint_splot() does with smxd, smyd */
    translucentlayer->mode.scale_xdiv = sprite->mode.scale_xmul;
    translucentlayer->mode.scale_ydiv = sprite->mode.scale_ymul;

    visdelay_begin ();
    ftracef0 ("About to attempt pending merge.\n");

    /* First we need to work around the fact BlendTable / InverseTable  *
     * only blends with RGB values of pixels and for transparent regions*
     * of sprites these are very often the wrong colour.                *
     * The workaround is to change the RGB colour of transparent pixels *
     * to the currently selected colour before the merge.               */
    if (translucency > 0 && psprite_hasmask (sprite) &&
        !psprite_canalphablend(sprite))
    {
      /* If not using gcol or tint we should possibly use white or 50% grey */
      sprite_colour scol = colours_pack_colour (translucentlayer,
          translucentlayer->gcol);
      set_transparent_RGB (sprite, &scol);
    }

    /* Ensure there's a palette before switching output to sprite */
    addpal = ensure_sprite_has_palette (sprite, &oldoffset);

    sprwindow_swap_output_to_sprite (sprite);

    if (tools_brush_use_gcol)
    {
      /* It doesn't really matter what the colour is here. We just need to
         ensure the logical operation is 0, Set */
      int mode = toolwindow_current_mode;
      main_colour gcol = sprite->gcol;
      gcol.alpha = 255;
      toolwindow_current_mode = 0; /* Set */
      colours_set_sprite_gcol (gcol, sprite, 1);
      toolwindow_current_mode = mode;
    }

    err = psprite_plot_scaled_m (0, 0, translucentlayer, &scale, 0, 0, translucency);
    if (err != NULL)
      goto finish;
    /* If the base sprite has a mask, we have to plot the layer's
       mask onto that to make the brush stroke opaque */
    if (psprite_hasmask (sprite))
    {
      sprwindow_swap_output_to_screen ();
      if (addpal) sprite->offset = oldoffset;
      sprwindow_swap_output_to_mask (sprite, 1);
      os_swi2 (OS_SetColour, 0, 0); /* set transparent foreground */
      os_swi2 (OS_SetColour, 1 << 4, -1); /* set solid background */
      err = psprite_plot_scaled_m (0, 0, translucentlayer, &scale, 0, 1, 0);
    }
    finish:
    Set_Marked_Extent (sprite);
    sprwindow_swap_output_to_screen ();
    /* Restore psprite's view and dispose of the palette */
    if (addpal) sprite->offset = oldoffset;
    /* We're done with that layer until next brush stroke */
    tools_delete_layer ();
    psprite_recalculate_offsets (sprite->file);
    sprwindow_redisplay (sprite, &Marked_Extent);
    visdelay_end ();
    wimpt_noerr (err);
  }
  else
    ftracef2 ("Merge not done. Layer: %x Merge pending?: %d\n",
              translucentlayer, toolslayer.mergepending);
}

static void brushpaint_splot (main_window *window, wimp_mousestr *mpos)

{
  int x, y;
  BOOL background;
  main_sprite *sprite = window->data->sprite.sprite;
  main_sprite *translucentlayer = NULL;
  BOOL madenewlayer = FALSE;
  BOOL workspacechanged = FALSE;
  BOOL maskforshape = FALSE;
  main_sprite *destsprite;
  tools_mouse_to_pixel (window, mpos, &x, &y);
  background = mpos->bbits == wimp_BRIGHT;
  main_colour gcol = background ? sprite->gcol2 : sprite->gcol;

  ftracef0 ("brushpaint_splot\n");

  if (x != sprite->toolspace [3] || y != sprite->toolspace [4])
  {
    main_ttab *ott = tools_brushsprite_ptr->transtab;
    int smxd = tools_brushsprite_ptr->mode.scale_xdiv;
    /*current mode pixel sizes*/
    int smyd = tools_brushsprite_ptr->mode.scale_ydiv;
    sprite_info sbi;
    sprite_id sid;
    int mul, div;
    main_sprite_window *swind = &window->data->sprite;
    unsigned char translucency;

    sid.s.addr = psprite_address (tools_brushsprite_ptr);
    sid.tag = sprite_id_addr;

    sprite_readsize (tools_brushsprite_ptr->file->spritearea, &sid, &sbi);

    /* now set dest mode pixel sizes */
    tools_brushsprite_ptr->mode.scale_xdiv = sprite->mode.scale_xmul;
    tools_brushsprite_ptr->mode.scale_ydiv = sprite->mode.scale_ymul;

    sprite->toolspace [3] = x;
    sprite->toolspace [4] = y;

    x   = tools_pixel_to_point_x(swind, sprite->toolspace [3]);
    mul = tools_brushsprite_ptr->mode.scale_xmul * tools_brushscale.scale_xmul;
    div = swind->sprite->mode.scale_xmul * tools_brushscale.scale_xdiv;
    x  -= tools_pixel_to_point_x(swind, (sbi.width*mul/div) / 2);

    y   = tools_pixel_to_point_y(swind, sprite->toolspace [4]);
    mul = tools_brushsprite_ptr->mode.scale_ymul * tools_brushscale.scale_ymul;
    div = swind->sprite->mode.scale_ymul * tools_brushscale.scale_ydiv;
    y  -= tools_pixel_to_point_y(swind, (sbi.height*mul/div) / 2);

    /* Read opacity */
    translucency = 255 - toolwindow_readopacityslider ();
    if (translucency > 0)
    {
      int nc = colours_count (sprite);
      /* Blending won't work well with < 256-colours, so disable that */
      if (nc < 256)
        translucency = 0;
      ftracef1 ("Translucency: %d\n", translucency);
    }

    /* Note also if we're painting in the fully transparent colour, with *
       Shape, we definitely don't want to use the translucentlayer */
    if (translucency > 0 && (gcol.alpha || tools_brush_use_gcol != 1))
    {
      translucentlayer = tools_get_layer (sprite);
      if (translucentlayer == NULL)
      {
        ftracef0 ("tools_get_layer returned NULL. Creating new layer.\n");
        ftracef1 ("window: %x\n", window);
        translucentlayer = tools_create_layer (window);
        madenewlayer = TRUE;
        ftracef1 ("tools_create_layer returned: %x\n", (int)translucentlayer);
      }
      if (translucentlayer == NULL)
      {
        /* Out of memory. */
        ftracef0 ("Couldn't create translucent brush layer.\n");
        destsprite = sprite;
        madenewlayer = FALSE;
      }
      else
      {
        /* Stash the colour of the brush stroke in the sprite's gcol and *
         * the layer opacity in its gcol.alpha, as this is otherwise *
         * unused since it's not a regular base sprite */
        translucentlayer->gcol = gcol;
        translucentlayer->gcol.alpha = (char)toolwindow_readopacityslider ();
        destsprite = translucentlayer;
        toolslayer.mergepending = TRUE;
      }
    }
    else
    {
      destsprite = sprite;
    }

    tools_brushsprite_ptr->transtab = (main_ttab *) /*dest*/sprite->toolspace [2];

    /* our transfer function now does shape except when using ECFs */
    maskforshape = tools_brush_use_gcol == 1 && gcol.ecf;

    if (!maskforshape && tools_brush_use_gcol && (gcol.alpha ||
        tools_brush_use_gcol == 1)) /* For transparent, Tint mode's unsupported. */
    {
      int bgr;
      BOOL shapeonly = tools_brush_use_gcol == 1;
      colours_set_sprite_gcol (gcol, sprite, 1);
      /* We must figure out the full palette entry for this colour. */
      bgr = colours_entry_from_gcol (sprite, background, /*force BGR*/TRUE);

      workspacechanged = psprite_init_brush_workspace (FALSE, shapeonly, (uint32_t)bgr, sprite);
    }
    else
    {
      /* This will disable the ColourTrans transfer function */
      workspacechanged = psprite_init_brush_workspace (TRUE, FALSE, 0, sprite);
    }

    if (workspacechanged || madenewlayer || sprite->toolspace [2] == 0)
    {
      wimpt_noerr (psprite_free_brush_blocks ());
      wimpt_noerr (psprite_set_brush_colour_translations ());

      /* this works on 256 colours, but only if the base sprite has a palette */

      tools_brushsprite_ptr->transtab = (main_ttab *) sprite->toolspace [2];
    }

    sprwindow_swap_output_to_sprite (destsprite);

    if (maskforshape)
    {
      /* We do Shape painting the old-fashioned way, by plotting the mask
      onto the sprite in the selected colour (or ECF pattern). */
      colours_set_sprite_gcol (gcol, sprite, 1);
    }

    psprite_plot_scaled_m (x, y, tools_brushsprite_ptr,
                           &tools_brushscale, toolwindow_current_mode,
                           maskforshape, 0);

    if (sprwindow_swap_output_to_mask (destsprite, 1))
    {
      BOOL c = (tools_brush_use_gcol == 1) && !gcol.alpha;

      os_swi2 (OS_SetColour, c? 0: 1 << 4, c? 0: -1);
#if 0
      /*replaces the following, avoiding need to check full-palette bit*/
      colour = tools_brush_use_gcol &&
          sprite->gcol == colours_count (sprite)? 0: 255;
      bbc_gcol (0, colour);
      bbc_tint (3, colour);
#endif
      psprite_plot_scaled_m (x, y,
          tools_brushsprite_ptr, &tools_brushscale, 0, 1, 0);
    }

    tools_brushsprite_ptr->transtab = ott;
    tools_brushsprite_ptr->mode.scale_xdiv = smxd;
    tools_brushsprite_ptr->mode.scale_ydiv = smyd;

    Set_Marked_Extent (sprite);
    sprwindow_swap_output_to_screen ();
    psprite_recalculate_offsets (sprite->file);
    sprwindow_redisplay (sprite, &Marked_Extent);
  }
}

static void brush_drawEOR(main_sprite_window *swind, int *toolspace, int x0, int y0)
{
  int x, y;
  main_scaling_block scale;
  sprite_info sbi;
  sprite_id sid;
  int mul, div;
  main_sprite *brushmouse;

  if (tools_brushmouse_ptr != NULL)
    brushmouse = tools_brushmouse_ptr;
  else if (tools_brushsprite_ptr == NULL)
    return;
  else
    brushmouse = tools_brushsprite_ptr;

  sid.s.addr = psprite_address (brushmouse);
  sid.tag = sprite_id_addr;

  sprite_readsize (brushmouse->file->spritearea, &sid, &sbi);

  scale.scale_xmul =
      tools_brushscale.scale_xmul*swind->blobsize.scale_xmul;
  scale.scale_xdiv =
      tools_brushscale.scale_xdiv*swind->blobsize.scale_xdiv;
  scale.scale_ymul =
      tools_brushscale.scale_ymul*swind->blobsize.scale_ymul;
  scale.scale_ydiv =
      tools_brushscale.scale_ydiv*swind->blobsize.scale_ydiv;

  /* find bottom left of brush. Pixel over pointer is aligned
     to pixel grid. */

  x = tools_pixel_to_extent_x(swind, toolspace [3]);
  mul=brushmouse->mode.scale_xmul*tools_brushscale.scale_xmul;
  div=swind->sprite->mode.scale_xmul*tools_brushscale.scale_xdiv;
  x-=tools_pixel_to_extent_x(swind,(sbi.width*mul/div)/2);

  y = tools_pixel_to_extent_y(swind, toolspace [4]);
  mul=brushmouse->mode.scale_ymul*tools_brushscale.scale_ymul;
  div=swind->sprite->mode.scale_ymul*tools_brushscale.scale_ydiv;
  y -= tools_pixel_to_extent_y(swind,(sbi.height*mul/div)/2);

  psprite_plot_scaled (x+x0, y+y0, brushmouse, &scale, 4);
}

static void brushEOR (main_sprite *sprite)

{
  main_sprite_window *swind;

  ftracef0 ("brushEOR\n");
  for (swind = sprite->windows; swind != NULL; swind = swind->link)
  {
    int more, x0, y0;
    wimp_redrawstr rds;

    sprite_update_window(swind,&x0,&y0,&rds,&more);
    while (more)
    {
      brush_drawEOR(swind, sprite->toolspace, x0, y0);
      wimpt_noerr (wimp_get_rectangle (&rds, &more));
    }
  }
}

/**************************************************
 * Brush: find named sprite, plot at current pos. *
 **************************************************/

static void brushpaint_click (main_window *window, wimp_mousestr *mpos)

{
  ftracef0 ("brushpaint_click\n");
  if ((mpos->bbits & (wimp_BLEFT | wimp_BRIGHT)) != 0 &&
      tools_brushsprite_ptr != NULL)
  {
    main_sprite *sprite = window->data->sprite.sprite;

    /* Read Shape / Stamp / Tint */
    toolwindow_readbrushmode ();

    /* Without this code, dragging the paint brush fails if attempted *
     * immediately after clicking a text icon on the colour picker in *
     * Edit Palette or the name on the Save dialogue.                 */
    sprwindow_claim_idle_events (window);    /* start tracking */

    if (sprite->toolspace [0] == 1) brushEOR (sprite);
    sprite->toolspace [0] = 2;    /* had click, no EOR */
    ftracef2 ("0x%X->toolspace [0]: 0x%X\n",
        sprite, sprite->toolspace [0]);
    sprite->toolspace [3] = sprite->toolspace [4] = -1;

    if ((psprite_hasalphachannel (tools_brushsprite_ptr) ||
        psprite_hasalphamask (tools_brushsprite_ptr)) &&
        psprite_hasmask (sprite))
    {
      /* Have to set the RGB colour of transparent regions otherwise it can
       * look wrong when the OS blends the brush with it. */
      sprite_colour scol = colours_pack_colour (sprite, sprite->gcol);
      set_transparent_RGB (sprite, &scol);
    }
    brushpaint_splot (window, mpos);
  }
}

/***********************************************************
 * Null events: if pointer is over a window on the sprite, *
 *    then another brush stroke                            *
 ***********************************************************/

static void brushpaint_null (main_window *window, wimp_mousestr *mpos)

{
  ftracef0 ("brushpaint_null\n");
  if (tools_brushsprite_ptr != NULL)
  {
    main_sprite *sprite = window->data->sprite.sprite;

    if (mpos->bbits == 0 || sprite->toolspace [0] != 2)
    /*if the mouse button is now up, stop tracking; don't start until click*/
    {
      int x, y;

      tools_mouse_to_pixel (window, mpos, &x, &y);

      if (x != sprite->toolspace [3] || y != sprite->toolspace [4] ||
          tools_get_layer (sprite) != NULL)
      {
        if (sprite->toolspace [0] == 1)
          brushEOR (sprite);         /* remove old copy */
        else
        {
          sprite->toolspace [0] = 1;
          ftracef2 ("0x%X->toolspace [0]: 0x%X\n",
              sprite, sprite->toolspace [0]);
        }
        tools_merge_layer_onto (sprite);

        sprite->toolspace [3] = x;
        sprite->toolspace [4] = y;

        brushEOR (sprite);
      }
    }
    else
      brushpaint_splot (window, mpos);
  }
}

static void stopbrush (main_sprite *sprite)

{
  ftracef0 ("stopbrush\n");
  if (sprite->toolspace [0] == 1 && tools_brushsprite_ptr != NULL)
    brushEOR (sprite);
  sprwindow_release_idle_events (sprite);
  sprite->toolspace [0] = 0;
  ftracef2 ("0x%X->toolspace [0]: 0x%X\n",
      sprite, sprite->toolspace [0]);
  tools_merge_layer_onto (sprite);
}

void tools_remove_brush (void)

{
  main_window *window;

  ftracef0 ("tools_remove_brush\n");
  /* remove any EORed brushes on screen */

  for (window = main_windows; window != NULL; window = window->link)
  if (window->tag == main_window_is_file)
  {
    main_sprite *sprite;
    for (sprite = window->data->file.sprites;
    sprite != NULL;
    sprite = sprite->link)
    if (sprite->toolspace [0] == 1) brushEOR (sprite);
  }
}

void tools_replace_brush (void)

{
  ftracef0 ("tools_replace_brush\n");
  tools_remove_brush ();
}

static void brushpaint_redraw (main_window *window, int x0, int y0)

{
  if (tools_brushsprite_ptr != NULL)
  {
    main_sprite_window *swind = &window->data->sprite;
    main_sprite *sprite = swind->sprite;
    ftracef0 ("brushpaint_redraw\n");

    if (sprite->toolspace [0] == 1)
      brush_drawEOR(swind, sprite->toolspace, x0, y0);
  }
}

/***********************************************************
 * Stop null events: general purpose tool closure routine  *
 ***********************************************************/

static void stopnulls (main_sprite *sprite)

{
  ftracef0 ("stopnulls\n");
  sprwindow_release_idle_events (sprite);
  sprite->toolspace [0] = 0;
  ftracef2 ("0x%X->toolspace [0]: 0x%X\n",
      sprite, sprite->toolspace [0]);
}

static void Skip (main_window *window, int x, int y)

{
  ftracef0 ("Skip\n");
  window = window; x = x; y = y;
}

